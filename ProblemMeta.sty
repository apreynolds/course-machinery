\ProvidesPackage{ProblemMeta}[2026/07/18 Greppable problem metadata (store only)]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% WHY THIS EXISTS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% The problem bank is one problem per file, pulled into documents with \import.
% So the question "which problems do I have about the chain rule?" has to be
% answerable WITHOUT running LaTeX -- nothing has \input those files yet at the
% moment you are deciding what to put on the test. That rules out any scheme
% where the metadata only exists once TeX has read it.
%
% Hence the metadata is a literal block that a script reads straight off disk:
%
%   \ProblemMeta{
%     topics     = {differentiation, power-rule},
%     tags       = {polynomial, routine},
%     difficulty = {basic},
%     source     = {Stewart 3.1},
%   }
%
% Keep ONE KEY PER LINE, values braced. The companion script (find-problems)
% parses the block textually, line by line; reflowing it onto a single line
% still compiles fine but makes the problem invisible to the script. That is the
% one way to get the two readers out of step, so it is worth the discipline.
%
% The LaTeX side is now STORE-ONLY: \ProblemMeta accepts the block (so the file
% compiles and a mistyped key is caught) but typesets nothing. It used to ALSO
% print the metadata in the margin under \def\ShowProblemMeta{}; that DISPLAY
% layer was removed 2026-07-18 once no build view still wanted it. To bring
% printed metadata back, restore a display section that reads the key values --
% the removed version (colours + \marginpar block) is in git history.
%
% NB `#' is special to LaTeX, so a source like `Stewart 3.1 #7' must be written
% `Stewart 3.1 \#7'. find-problems knows this and reports it back without the
% backslash.

\RequirePackage{keyval}

% The keys are ACCEPTED but their values are discarded -- validation only, so a
% mistyped key (`topic' for `topics') errors at compile time. The metadata itself
% is read off disk by find-problems, never from these. Add handlers here again if
% a future display layer needs the values stored.
\define@key{ProblemMeta}{topics}    {}
\define@key{ProblemMeta}{tags}      {}
\define@key{ProblemMeta}{difficulty}{}
\define@key{ProblemMeta}{source}    {}
\define@key{ProblemMeta}{id}        {}

\newcommand{\ProblemMeta}[1]{\setkeys{ProblemMeta}{#1}\ignorespaces}
