#!/usr/bin/env bash
# find-problems — search the problem bank by its \ProblemMeta metadata
# Usage: find-problems [--topic PAT] [--type PAT] [--difficulty PAT]
#                      [--source PAT] [--untagged] [--vocab] [--tsv]
#                      [--import [--with LIST] [--from DIR]] [PATH ...]
#
# Reads the \ProblemMeta{...} block out of every .tex file under each DIR
# (default: the current directory, recursively) and reports the files that
# match. With no filters, reports every file that has a block.
#
# Filters (all optional, combined with AND):
#   --topic PAT       match a topic
#   --type PAT        match a type (problem form / character)
#   --difficulty PAT  match the difficulty
#   --source PAT      match the source
#
# PAT is an extended regular expression, matched case-insensitively against each
# comma-separated item in turn -- so `--topic power' finds `power-rule', and
# `--topic '^power-rule$'' matches only that. A filter for a key a file does not
# set never matches, so --difficulty basic will not report untagged files.
#
# Other modes:
#   --untagged  invert: list .tex files with NO \ProblemMeta block at all, i.e.
#               the backlog of problems still to be tagged.
#   --vocab     ignore filters and instead print the type/topic vocabulary in
#               use, with counts. This is the antidote to a bank where half the
#               problems say `integration' and half say `integrals' -- read it
#               before inventing a new type.
#   --import    print matches as paste-ready \importproblem lines, instead of
#               the default listing. Two opt-in modifiers refine the output:
#     --with LIST   a comma-separated subset of {number, desc}: inject those
#                   metadata keys as \importproblem options for files that carry
#                   them (silently omitted where absent). points stays manual --
#                   it is extrinsic, set at the import site, never auto-filled.
#     --from DIR    rewrite each line's directory argument relative to DIR (the
#                   folder of the importing document), so pasted lines need no
#                   ../ hand-fixing.
#   --tsv       print one tab-separated row per match --
#               path<TAB>desc<TAB>topics<TAB>type<TAB>difficulty<TAB>source<TAB>number
#               -- as the machine-readable feed for a picker (see pick-problems).
#               Respects the filters, so they can pre-narrow what is offered.
#
# An operand may be a directory (walked recursively) or a single .tex file, so a
# picker can ask --import about exactly the files it selected.
#
# Output (default) is one block per match: the path, then its metadata.
#
# The parser is textual and deliberately simple: it wants one key per line
# inside the block, with the value braced, as ProblemMeta.sty's own header asks
# for. A block reflowed onto one line still compiles but will not be seen here.

set -uo pipefail

usage() {
  # Reprint the header block (line 2 to the first blank line), stripping the
  # leading "# ", so -h stays in sync with the comment above. Same trick as
  # build-pdfs.
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
}

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# ARGUMENTS
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
topic="" type_="" difficulty="" source=""
with_keys="" from_dir=""    # --import modifiers (see validation below)
mode="list"          # list | vocab | import | untagged | tsv
paths=()             # search operands: directories and/or individual files

while [[ $# -gt 0 ]]; do
  case $1 in
    -h | --help)   usage; exit 0 ;;
    --topic)       topic=${2:?--topic needs a pattern};      shift 2 ;;
    --type)        type_=${2:?--type needs a pattern};       shift 2 ;;
    --difficulty)  difficulty=${2:?--difficulty needs a pattern}; shift 2 ;;
    --source)      source=${2:?--source needs a pattern};    shift 2 ;;
    --vocab)       mode="vocab";    shift ;;
    --import)      mode="import";   shift ;;
    --untagged)    mode="untagged"; shift ;;
    --tsv)         mode="tsv";      shift ;;
    --with)        with_keys=${2:?--with needs a comma-separated key list}; shift 2 ;;
    --from)        from_dir=${2:?--from needs a directory};                 shift 2 ;;
    -*)            echo "find-problems: unknown option: $1" >&2
                   echo "Try 'find-problems --help'." >&2
                   exit 2 ;;
    *)             paths+=("$1"); shift ;;
  esac
done

# --with / --from only make sense as modifiers of --import; reject them anywhere
# else so a silent no-op cannot hide a typo.
if [[ -n $with_keys || -n $from_dir ]] && [[ $mode != import ]]; then
  echo "find-problems: --with/--from only apply with --import" >&2
  exit 2
fi

# --with takes a comma-separated subset of the injectable keys -- and ONLY those
# two: number and desc are the only ProblemMeta keys that map to \importproblem
# options, so the set is deliberately closed (no per-key flag creep). Collect the
# request as a set for the emitter below.
declare -A want=()
if [[ -n $with_keys ]]; then
  IFS=, read -ra _wk <<< "$with_keys"
  for k in "${_wk[@]}"; do
    k="${k//[[:space:]]/}"                 # tolerate `number, desc' and trailing commas
    case $k in
      number | desc) want[$k]=1 ;;
      "") ;;
      *) echo "find-problems: --with accepts only number,desc (got: $k)" >&2; exit 2 ;;
    esac
  done
fi

if [[ -n $from_dir && ! -d $from_dir ]]; then
  echo "find-problems: --from: not a directory: $from_dir" >&2
  exit 2
fi

[[ ${#paths[@]} -eq 0 ]] && paths=(".")

# Operands may be directories (walked recursively) or individual .tex files --
# the picker's accept action passes specific selected files. `find' handles a
# mix of both; we only insist each operand exists.
for p in "${paths[@]}"; do
  if [[ ! -e $p ]]; then
    echo "find-problems: no such file or directory: $p" >&2
    exit 2
  fi
done

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# READING A BLOCK
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Prints one "key<TAB>value" line per key found in the file's \ProblemMeta
# block, or nothing at all if the file has no block. Everything downstream
# works off this, so the parsing rules live in exactly one place.
read_meta() {
  awk '
    # The block opens on the line carrying \ProblemMeta{ ...
    /\\ProblemMeta[[:space:]]*\{/ { inblock = 1; next }

    # ... and closes at the first line starting with a brace.
    inblock && /^[[:space:]]*\}/ { inblock = 0; next }

    inblock {
      line = $0

      # Strip trailing LaTeX comments, but not an escaped \% inside a value.
      # Park the escaped ones under a byte that cannot occur in a .tex source,
      # cut at the first surviving %, then put them back.
      gsub(/\\%/, "\001", line)
      sub(/%.*$/, "", line)
      gsub(/\001/, "\\%", line)

      # A key line looks like:  name = {value},
      if (match(line, /^[[:space:]]*[A-Za-z]+[[:space:]]*=/)) {
        key = line
        sub(/[[:space:]]*=.*$/, "", key)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)

        val = line
        sub(/^[^=]*=[[:space:]]*/, "", val)   # drop up to and including the =
        sub(/,[[:space:]]*$/, "", val)        # drop the trailing comma
        gsub(/^\{|\}$/, "", val)              # drop the surrounding braces
        gsub(/\\#/, "#", val)                 # \# is how you must write # in TeX
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)

        printf "%s\t%s\n", key, val
      }
    }
  ' "$1"
}

# Pull one key out of a block dump (as produced by read_meta).
field() {
  local dump=$1 key=$2
  printf '%s\n' "$dump" | awk -F'\t' -v k="$key" '$1 == k { print $2; exit }'
}

# Print TARGET as a path relative to BASE (both absolutised first). Used by
# --from to make emitted \importproblem directory arguments relative to the
# importing document. macOS's BSD realpath has no --relative-to, so lean on perl
# -- already a hard dependency of this repo (every .latexmkrc uses it) -- and its
# core File::Spec::abs2rel.
relpath() {
  perl -MFile::Spec -MCwd -e \
    'print File::Spec->abs2rel(Cwd::abs_path($ARGV[0]), Cwd::abs_path($ARGV[1]))' \
    "$1" "$2"
}

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# MATCHING
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Does any comma-separated item in $1 match the ERE in $2? An empty pattern
# means "no filter asked for", which matches everything -- including files that
# do not set the key at all.
csv_matches() {
  local list=$1 pattern=$2 item
  [[ -z $pattern ]] && return 0
  local IFS=,
  for item in $list; do
    item="${item#"${item%%[![:space:]]*}"}"     # trim leading whitespace
    item="${item%"${item##*[![:space:]]}"}"     # trim trailing whitespace
    [[ -z $item ]] && continue
    if [[ ${item,,} =~ ${pattern,,} ]]; then return 0; fi
  done
  return 1
}

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# WALK
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# -print0 / read -d '' so paths with spaces survive. Aux and build output never
# live beside the sources here, but .git might, so prune it.
files=()
while IFS= read -r -d '' f; do
  files+=("$f")
done < <(find "${paths[@]}" -name .git -prune -o -type f -name '*.tex' -print0 | sort -z)

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# FAST PATH: --tsv
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# --tsv is the machine feed for an interactive picker, so it has to be quick. The
# generic loop below spawns read_meta plus a field() per key for EVERY file --
# one awk process each, hundreds to thousands of forks -- which is fine for a
# human-read listing but makes a fzf source feel laggy. So --tsv gets its own
# route: a SINGLE awk parses every file in one pass, applies the filters itself,
# and prints the rows. It reuses read_meta's exact parsing rules and csv_matches'
# exact semantics (case-insensitive ERE per comma-separated item), so the output
# is byte-identical to what the generic path would produce -- just ~100x faster.
# Filter patterns travel via the environment (fp_*), not awk -v, so awk's -v
# backslash-escape processing cannot mangle a pattern. Columns match the tsv
# report branch below.
if [[ $mode == tsv ]]; then
  [[ ${#files[@]} -eq 0 ]] && exit 0
  printf '%s\0' "${files[@]}" \
    | fp_topic="$topic" fp_type="$type_" fp_difficulty="$difficulty" fp_source="$source" \
      xargs -0 awk '
      function csv_match(value, pattern,   n, arr, i, item) {
        if (pattern == "") return 1
        n = split(value, arr, ",")
        for (i = 1; i <= n; i++) {
          item = arr[i]
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", item)
          if (item != "" && tolower(item) ~ tolower(pattern)) return 1
        }
        return 0
      }
      BEGIN {
        ft = ENVIRON["fp_topic"]; fy = ENVIRON["fp_type"]
        fd = ENVIRON["fp_difficulty"]; fs = ENVIRON["fp_source"]
      }
      # New file: reset state. split("",v) empties the array portably.
      FNR == 1 { path = FILENAME; inblock = 0; split("", v) }
      /\\ProblemMeta[[:space:]]*\{/ { inblock = 1; next }
      # Block close: filter, then emit one row. Same column order as the report.
      inblock && /^[[:space:]]*\}/ {
        inblock = 0
        if (csv_match(v["topics"], ft) && csv_match(v["type"], fy) &&
            csv_match(v["difficulty"], fd) && csv_match(v["source"], fs))
          printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n",
                 path, v["desc"], v["topics"], v["type"], v["difficulty"], v["source"], v["number"]
        next
      }
      # Key line inside the block -- read_meta parsing rules, verbatim.
      inblock {
        line = $0
        gsub(/\\%/, "\001", line); sub(/%.*$/, "", line); gsub(/\001/, "\\%", line)
        if (match(line, /^[[:space:]]*[A-Za-z]+[[:space:]]*=/)) {
          key = line; sub(/[[:space:]]*=.*$/, "", key); gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
          val = line; sub(/^[^=]*=[[:space:]]*/, "", val); sub(/,[[:space:]]*$/, "", val)
          gsub(/^\{|\}$/, "", val); gsub(/\\#/, "#", val); gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
          v[key] = val
        }
      }
    '
  exit 0
fi

matches=()
declare -A meta_of=()

for f in "${files[@]}"; do
  dump=$(read_meta "$f")

  if [[ $mode == untagged ]]; then
    [[ -z $dump ]] && matches+=("$f")
    continue
  fi

  [[ -z $dump ]] && continue          # no block -> not part of the bank

  # --vocab really does ignore the filters (as its help text promises): the
  # vocabulary must cover the whole bank, so every tagged file counts.
  if [[ $mode != vocab ]]; then
    csv_matches "$(field "$dump" topics)"     "$topic"      || continue
    csv_matches "$(field "$dump" type)"       "$type_"      || continue
    csv_matches "$(field "$dump" difficulty)" "$difficulty" || continue
    csv_matches "$(field "$dump" source)"     "$source"     || continue
  fi

  matches+=("$f")
  meta_of["$f"]=$dump
done

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# REPORT
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
case $mode in
  vocab)
    # Counts across every block found, per key. Filters are ignored: the point
    # is to see the whole vocabulary before adding to it.
    for key in topics type difficulty; do
      echo "$key:"
      for f in "${matches[@]}"; do
        field "${meta_of[$f]}" "$key" | tr ',' '\n'
      done | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' | grep -v '^$' \
           | sort | uniq -c | sort -rn | sed 's/^/  /'
      echo
    done
    ;;

  import)
    # \importproblem is the wrapper a document actually wants (it reboxes the
    # imported file and carries the metadata options); its signature is
    # [opts]{dir/}{file}. The dir/file split is relative to the importing
    # document. Without --from we cannot know that document, so paths come out
    # relative to the search root and usually need a ../ or two (paste and
    # adjust); --from does the ../ for you.
    for f in "${matches[@]}"; do
      file=$(basename "$f")
      if [[ -n $from_dir ]]; then
        dir=$(relpath "$(dirname "$f")" "$from_dir")
      else
        dir=$(dirname "$f")
      fi

      # Injected options, in a fixed canonical order regardless of --with order.
      # A file that lacks a requested key is silently skipped for that key. Any
      # `#' has to be re-escaped to `\#': read_meta un-escaped it on the way in
      # (\# -> #), but `\%' it left intact, so % needs no re-escaping here.
      opts=""
      for key in number desc; do
        [[ -n ${want[$key]:-} ]] || continue
        v=$(field "${meta_of[$f]}" "$key")
        [[ -n $v ]] || continue
        v=${v//'#'/\\#}
        opts+="${opts:+, }${key}={${v}}"
      done

      if [[ -n $opts ]]; then
        printf '\\importproblem[%s]{%s/}{%s}\n' "$opts" "$dir" "$file"
      else
        printf '\\importproblem{%s/}{%s}\n' "$dir" "$file"
      fi
    done
    ;;

  tsv)
    # One tab-separated row per match, for a picker (fzf) to read. Column 1 is
    # the path -- hidden from the picker's display, but kept because it is what
    # opens/previews the file and what feeds back into --import. The rest are the
    # searchable metadata, in a fixed order. Values never contain a tab (LaTeX
    # has none), and a key a file omits yields an empty cell.
    for f in "${matches[@]}"; do
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$f" \
        "$(field "${meta_of[$f]}" desc)" \
        "$(field "${meta_of[$f]}" topics)" \
        "$(field "${meta_of[$f]}" type)" \
        "$(field "${meta_of[$f]}" difficulty)" \
        "$(field "${meta_of[$f]}" source)" \
        "$(field "${meta_of[$f]}" number)"
    done
    ;;

  untagged)
    printf '%s\n' "${matches[@]}"
    echo >&2
    echo "${#matches[@]} file(s) with no \\ProblemMeta block." >&2
    ;;

  list)
    for f in "${matches[@]}"; do
      echo "$f"
      printf '%s\n' "${meta_of[$f]}" | sed 's/^/    /; s/\t/: /'
      echo
    done
    echo "${#matches[@]} match(es)." >&2
    ;;
esac
