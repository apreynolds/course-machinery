#!/usr/bin/env bash
# find-problems — search the problem bank by its \ProblemMeta metadata.
# A thin shim over find-meta (the shared engine); `--help' lists the concrete
# problem filters (--topic/--type/--difficulty/--source). See find-meta and
# ProblemMeta.sty.
exec "$(dirname -- "$0")/find-meta" --kind problem --as find-problems "$@"
