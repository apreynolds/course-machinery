\ProvidesPackage{Workspace}[2026/07/18 explicit handwriting whitespace: \string\workspace]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% WHAT THIS IS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Tests and lecture notes need COPIOUS blank vertical space for handwriting --
% students working a problem, or the instructor improvising at the board -- which
% is not the LaTeX norm. \workspace reserves that space EXPLICITLY and visibly in
% the source (so it can be eyeballed and tuned in the editor), as a LEAF command
% between content, never a wrapper -- so a source folded by content environments
% (example / theorem / solution / definition) stays readable.
%
%   \workspace            8 lines (the default)
%   \workspace[12]        12 lines
%   \workspace[halfpage]  ~half the text block  (0.5\textheight - 1 line, so a
%                         line at the page TOP ends up vertically centred: equal
%                         space above and below it)
%   \workspace[fullpage]  the whole text block  (\textheight; TEXT height, not paper)
%   \workspace*           fill to the bottom of the page (\vfill)
%
% The unit is a LINE OF HANDWRITING (\HandwritingLine, ~0.9cm), because "give me
% about ten lines" is how you actually think about writing room -- centimetres are
% not. Retune \HandwritingLine once and every line-count \workspace follows.
%
% BUILD-AGNOSTIC: the space is identical in every build (student, solutions,
% instructor). Deliberate -- it is the fixed foundation a future step will fill
% (hidden solution/InstructorBox content rendered INTO the reserved room as a
% zero-height overlay, so the copies share ONE layout). Until that step lands, a
% solutions key shows the blank space AND the printed solution below it; expected,
% not a bug -- do NOT make \workspace collapse in the solutions build.
%
% NO CARRY-OVER (by choice): a \workspace is plain vertical space. If it is larger
% than the room left on the page, the overflow is simply dropped and the following
% content starts the next page -- the space does NOT reappear on the next page. This
% matches the way these documents are actually laid out: content at the top of each
% page, whitespace beneath, and the rare page where a workspace would not fit is
% re-spaced BY HAND (move the offending content to the next page) rather than having a
% workspace silently push a half-page gap onto the next page. Simple on purpose, not
% precious about page boundaries. (One consequence of plain \vspace: an amount placed
% at the very TOP of a page is discarded like any top-of-page glue -- put content
% above it, or use \workspace* to fill a page from the top.)

\RequirePackage{etoolbox}   % \ifstrequal: the halfpage/fullpage keywords

% One line of handwriting room. Tunable; every line-count \workspace scales with it.
\newlength{\HandwritingLine}
\setlength{\HandwritingLine}{0.9cm}

% \workspace[amount] / \workspace* -- reserve blank writing space.
%   *         -> \vfill (fill to the page bottom); elastic, so nothing to guarantee.
%   halfpage  -> 0.5\textheight - \baselineskip (see below)
%   fullpage  -> \textheight
%   <number>  -> that many \HandwritingLine's (default 8)
% \textheight is read at USE time (in the body), so geometry has long since set it;
% loading this package before geometry is therefore fine.
\NewDocumentCommand{\workspace}{s O{8}}{%
  \par
  \IfBooleanTF{#1}
    {\vfill}%
    {\ifstrequal{#2}{halfpage}
       % 0.5\textheight would put half a page BETWEEN the flanking lines, but the
       % lines themselves eat into the room BELOW -- so the bottom gap comes up
       % short by ~their combined height. Subtracting one \baselineskip (the mean
       % of two single lines) equalises the gaps for a line sitting at the page top.
       {\workspace@fixed{\dimexpr0.5\textheight-\baselineskip\relax}}%
       {\ifstrequal{#2}{fullpage}
          {\workspace@fixed{\textheight}}%
          {\workspace@fixed{#2\HandwritingLine}}%
       }%
    }%
}

% Reserve a FIXED amount as ordinary vertical space -- deliberately NOT an unbreakable
% block, so it never carries a big gap onto the next page (see NO CARRY-OVER above).
\newcommand{\workspace@fixed}[1]{\vspace{#1}}

\endinput
