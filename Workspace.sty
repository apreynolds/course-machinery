\ProvidesPackage{Workspace}[2026/07/18 explicit handwriting whitespace: \string\workspace]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% WHAT THIS IS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Tests and lecture notes need COPIOUS blank vertical space for handwriting --
% students working a problem, or the instructor improvising at the board -- which
% is not the LaTeX norm. \workspace reserves that space EXPLICITLY and visibly in
% the source (so it can be eyeballed and tuned in the editor), as a LEAF command
% between content, never a wrapper -- so a source folded by content environments
% (example / theorem / solution / definition) stays readable.
%
%   \workspace            8 lines (the default)
%   \workspace[12]        12 lines
%   \workspace[halfpage]  ~half the text block  (0.5\textheight - 1 line, so a
%                         line at the page TOP ends up vertically centred: equal
%                         space above and below it)
%   \workspace[fullpage]  the whole text block  (\textheight; TEXT height, not paper)
%   \workspace*           fill to the bottom of the page (\vfill)
%
% The unit is a LINE OF HANDWRITING (\HandwritingLine, ~0.9cm), because "give me
% about ten lines" is how you actually think about writing room -- centimetres are
% not. Retune \HandwritingLine once and every line-count \workspace follows.
%
% BUILD-AGNOSTIC BY DEFAULT (overlay mode): the space is identical in every build
% (student, solutions, instructor), because the optional boxes (solution / hint /
% InstructorBox) render as ZERO-HEIGHT OVERLAYS into this reserved room (see the
% OVERLAY vs SOLID MODE section below) -- so a solutions/instructor copy is a
% pixel-perfect overlay of the student copy. The ONE exception is SOLID MODE
% (\solidboxes, opt-in and document-wide): there those boxes render at full height
% and \workspace collapses to nothing, giving a compact answer key. So \workspace
% DOES collapse -- but only under \solidboxes, never silently per-build.
%
% NO CARRY-OVER (by choice): a \workspace is plain vertical space. If it is larger
% than the room left on the page, the overflow is simply dropped and the following
% content starts the next page -- the space does NOT reappear on the next page. This
% matches the way these documents are actually laid out: content at the top of each
% page, whitespace beneath, and the rare page where a workspace would not fit is
% re-spaced BY HAND (move the offending content to the next page) rather than having a
% workspace silently push a half-page gap onto the next page. Simple on purpose, not
% precious about page boundaries. (One consequence of plain \vspace: an amount placed
% at the very TOP of a page is discarded like any top-of-page glue -- put content
% above it, or use \workspace* to fill a page from the top.)

\RequirePackage{etoolbox}   % \ifstrequal: the halfpage/fullpage keywords

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% OVERLAY vs SOLID MODE (document-wide)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% The point of \workspace is a layout the annotated copies SHARE with the student
% copy. Two document-wide modes, flipped by a preamble switch:
%
%   (default) OVERLAY -- optional boxes (solution / hint / InstructorBox) render at
%             ZERO HEIGHT, painting DOWN into the \workspace reserved below them, so
%             they never shift the layout: the solutions/instructor copy is a
%             pixel-perfect overlay of the student copy.
%   \solidboxes   SOLID -- those boxes render at NORMAL height and the reserved
%             room (\workspace, and \FreshPage's breaks / blank pages) collapses to
%             nothing: a compact answer key. Set once in the preamble.
%   \overlayboxes -- back to the default (for completeness / local re-enable).
%
% \ifWorkspaceOverlay is the flag both THIS package (the \workspace collapse below)
% and the box packages (Exercises' solution/hint, InstructorNotes' InstructorBox)
% read. Those packages stay self-contained: they route their box through
% \WSZeroHeight only when it exists (an \AtBeginDocument \providecommand identity
% fallback), so without this package -- e.g. under CourseDocument -- boxes render
% normally and nothing here is required.
\newif\ifWorkspaceOverlay
\WorkspaceOverlaytrue
\newcommand{\solidboxes}{\WorkspaceOverlayfalse}
\newcommand{\overlayboxes}{\WorkspaceOverlaytrue}

% \WSZeroHeight{<a complete \begin{tcolorbox}...\end{tcolorbox}>} -- in OVERLAY mode
% emit that box at ZERO height and depth so it paints DOWNWARD over the \workspace
% that follows WITHOUT displacing anything; in SOLID mode emit it unchanged.
%
% Mechanism (all in VERTICAL mode -- emitting on a text line would add that line's
% height, which is the whole thing we are avoiding):
%   1. capture into a \vtop -- reference point at the TOP, so the material sits in
%      the box's DEPTH (below the current baseline), i.e. it paints DOWNWARD;
%   2. force \ht and \dp to 0pt, so TeX reserves no vertical room for the box;
%   3. \nointerlineskip so no baseline glue is inserted BEFORE the zero box, then
%      restore \prevdepth afterwards -- so the FOLLOWING content (the \workspace)
%      is placed EXACTLY as if this box had never been emitted. That equality is
%      the point: the annotated copy overlays the student copy to the pixel.
% A box TALLER than the workspace below it simply overprints the following content
% -- the intended "leave more room" alarm, not a bug. (A breakable tcolorbox in a
% \vtop renders unbroken, which is right: an overlay is a fixed stamp, not paged.)
\newsavebox{\WS@ovbox}
\newdimen\WS@prevdp
\newcommand{\WSZeroHeight}[1]{%
  \ifWorkspaceOverlay
    \par
    \setbox\WS@ovbox=\vtop{#1}%          % build (its own inner list; outer list untouched)
    \ht\WS@ovbox=\z@ \dp\WS@ovbox=\z@     % report zero height + depth
    \WS@prevdp=\prevdepth                 % remember the exact vertical position
    \nointerlineskip \box\WS@ovbox        % paint, with no glue before it
    \prevdepth=\WS@prevdp                 % restore: following content is unshifted
  \else
    #1%
  \fi
}

% One line of handwriting room. Tunable; every line-count \workspace scales with it.
\newlength{\HandwritingLine}
\setlength{\HandwritingLine}{0.9cm}

% \workspace[amount] / \workspace* -- reserve blank writing space.
%   *         -> \vfill (fill to the page bottom); elastic, so nothing to guarantee.
%   halfpage  -> 0.5\textheight - \baselineskip (see below)
%   fullpage  -> \textheight
%   <number>  -> that many \HandwritingLine's (default 8)
% \textheight is read at USE time (in the body), so geometry has long since set it;
% loading this package before geometry is therefore fine.
% In OVERLAY mode (default) this reserves the space as documented. In SOLID mode
% (\solidboxes) the whole body collapses to just \par -- the boxes now carry their
% own height, so the reserved handwriting room is exactly what we drop.
\NewDocumentCommand{\workspace}{s O{8}}{%
  \par
  \ifWorkspaceOverlay
    \IfBooleanTF{#1}
      {\vfill}%
      {\ifstrequal{#2}{halfpage}
         % 0.5\textheight would put half a page BETWEEN the flanking lines, but the
         % lines themselves eat into the room BELOW -- so the bottom gap comes up
         % short by ~their combined height. Subtracting one \baselineskip (the mean
         % of two single lines) equalises the gaps for a line sitting at the page top.
         {\workspace@fixed{\dimexpr0.5\textheight-\baselineskip\relax}}%
         {\ifstrequal{#2}{fullpage}
            {\workspace@fixed{\textheight}}%
            {\workspace@fixed{#2\HandwritingLine}}%
         }%
      }%
  \fi
}

% Reserve a FIXED amount as ordinary vertical space -- deliberately NOT an unbreakable
% block, so it never carries a big gap onto the next page (see NO CARRY-OVER above).
\newcommand{\workspace@fixed}[1]{\vspace{#1}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \FreshPage -- COLLAPSIBLE PAGE BREAKS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% One command, three forms -- ALL of which VANISH under \solidboxes (page breaks and
% extra-work pages are layout for the spacing copy, not the compact answer key):
%
%   \FreshPage             a collapsible \newpage: break to a fresh page your content
%                          then flows ONTO (flush at the top, exactly as \newpage).
%   \FreshPage[blank]      a DEDICATED blank page -- nothing on it; following content
%                          starts the NEXT page. The [blank] keyword is purely a
%                          visible reminder in the source that the blank is deliberate.
%   \FreshPage[watermark]  a dedicated blank page carrying a faint diagonal watermark
%                          ("Blank page for extra work") -- the back-of-the-test
%                          "use this space if you need it" page.
%
% The difference between the no-argument form and [blank]: no argument is a BARE
% \newpage, so content SHARES the fresh page; [blank]/[watermark] force an EMPTY page
% (via \null) and push following content to the page after. Any keyword other than
% watermark behaves like [blank]. Plain \newpage stays untouched for the rare break
% that must NEVER collapse.
%
% WHY AN ARGUMENT, NOT \newpage[...]: \newpage is a LaTeX kernel command (\clearpage
% and the float mechanism call it internally). Giving IT an optional argument would
% make it scan for a following "[", silently swallowing a bracket that legitimately
% opens the next line -- a paragraph starting "[0,1] is ...". So \newpage is left
% untouched and the collapsible break gets its own verb. \FreshPage has the same, far
% smaller "[" caveat: put a blank line or a structural command after it -- as you
% always would -- and its optional-arg scan stops at the paragraph break.
%
% The watermark uses eso-pic's PER-PAGE background hook -- \AddToShipoutPictureBG*
% clears itself after that one shipout -- the same shipout-background route the
% instructor frame takes, and deliberately NOT the "background" package (which warns
% about everypage / the LaTeX version and needs a \WarningFilter to hush; eso-pic
% does neither).
\RequirePackage{eso-pic}    % per-page shipout background -> the watermark
\RequirePackage{graphicx}   % \rotatebox -> the diagonal watermark
\RequirePackage{color}      % \color[gray]{..}; lighter than xcolor, no option clash

% --- TWEAK HERE: the watermark's wording and look ---------------------------
\newcommand{\BlankPageText}{Blank page for extra work}
\newcommand{\freshpage@mark}{%
  \AtPageCenter{\makebox(0,0){%
    \rotatebox{45}{%
      % \color goes AFTER \selectfont, not before: colour-before-font-selection
      % inside this rotated shipout box can error ("Missing }") if the page ever also
      % carries body content (a font-selection/colour-group clash). \FreshPage always
      % watermarks a BLANK page, so it is not strictly needed here -- but this order
      % is robust either way and costs nothing. Same pixels.
      \sffamily\bfseries\fontsize{1.4cm}{1.4cm}\selectfont\color[gray]{0.85}%
      \BlankPageText}}}%
}

% In OVERLAY mode (default) \FreshPage ships as documented; in SOLID mode it emits
% nothing (the break, and any blank/extra-work page, collapses). The leading \newpage
% is shared by all three forms: for the NO-ARGUMENT form it IS the whole break, so
% content flows onto the fresh page flush at the top (a bare \newpage -- no \null, no
% shift). For [blank]/[watermark] that \newpage ships the preceding page, then \null
% + a second \newpage ship a DEDICATED empty (optionally watermarked) page.
%
% TWEAK: the blank/fresh page keeps the running page number/footer; add
% \thispagestyle{empty} in the keyword branch for a fully bare page instead.
\NewDocumentCommand{\FreshPage}{O{}}{%
  \ifWorkspaceOverlay
    \par
    \newpage
    \ifstrequal{#1}{}%
      {}%                        % no argument: a bare collapsible break; content flows on
      {% a keyword -> a DEDICATED blank page ([watermark] also stamps the mark)
        \ifstrequal{#1}{watermark}{\AddToShipoutPictureBG*{\freshpage@mark}}{}%
        \null                    % the one box that makes the empty page actually ship
        \newpage                 % ship the blank page; following content starts fresh
      }%
  \fi
}

\endinput
