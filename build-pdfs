#!/usr/bin/env bash
# build-pdfs — compile course .tex files into PDFs with latexmk
# Usage: build-pdfs [FILE.tex ...]
#
# With no arguments, compiles every *.tex file in the current directory.
# Each source FILE.tex produces FILE.pdf.
#
# Output mirror via a top-level .OUTDIR file: build-pdfs looks upward from the
# build directory for a .OUTDIR (at the repo top level, found the way .latexmkrc
# finds .course-machinery). Its first bare line names a base directory (a leading
# ~ is expanded) that mirrors the repo tree, so a source built in
# REPO/integrals/lectures ships to BASE/integrals/lectures. The mirror sub-
# directory is created if absent, but the base itself must exist — otherwise
# (e.g. the cloud is unmounted) build-pdfs warns and builds locally rather than
# scattering a stray tree. By default the build goes straight to the mirror (no
# local copy); add a line reading BOTH to build locally AND copy the PDF to the
# mirror, keeping both. Blank and #-comment lines are ignored; the path and the
# BOTH keyword may appear in either order. A nearer .OUTDIR (in a subdirectory)
# wins, letting a subtree mirror elsewhere. (COPY, a songsheets synonym for
# BOTH, is intentionally not recognised here yet.)
#
# Named destinations for selected views: besides the bare mirror-base line, a
# .OUTDIR may carry `LABEL: path' lines (e.g. `TA-dir: ~/shared/calc-ta'). A view
# in the magic comment below may name one with a colon suffix — `instructor:TA-dir'
# — which drops that view's PDF, flat, into the labelled directory IN ADDITION to
# the mirror. The labelled directory must already exist; a missing label or
# directory warns and skips that one extra copy without failing the build. This
# keeps machine-specific paths out of the (git-tracked) source: the source names a
# label, the git-ignored .OUTDIR maps it to a path.
#
# Views via a magic comment: a `%! views: ...' line in the leading comment block
# of a source (before \documentclass) requests extra PDFs. Four views are wired:
#   solutions -> also build FILE-SOLUTIONS.pdf, with \def\ShowSolutions{}
#                injected so \begin{solution} content the student build omits
#                is shown.
#   hints     -> also build FILE-HINTS.pdf, with \def\ShowHints{} injected so
#                \begin{hint} content is shown. Independent of solutions -- a hint
#                is student-facing help, so list both views for both PDFs.
#   projector -> also build FILE-PROJECTOR.pdf, with \def\ProjectorView{}
#                injected so the `LectureNotes' class switches to the room copy
#                (17pt, wider text, tighter top margin) instead of the handout.
#   instructor-> also build FILE-INSTRUCTOR.pdf, the instructor bundle: injects
#                \ShowSolutions + \ShowHints + \ShowInstructorNotes, so the
#                instructor copy shows solutions, hints, the slate staff notes,
#                and the page-edge frame. A view is a bundle of layers. (The
#                instructor copy IS the staff copy -- TAs get it too; there is no
#                separate marker tier.)
# Any other view name warns and is skipped.
# View PDFs follow the same mirror / BOTH handling as the default build. Any view
# may take a `:LABEL' suffix (see above) to also drop a flat copy into a named
# directory. `default' is a pseudo-view naming the base (student) PDF itself, wired
# only so it too can carry such a label -- a bare `default' is a harmless no-op.
#
# NB the class reads these as \ifdefined, so the same source builds both ways
# with no option at the call site -- see LectureNotes.cls / Assessment.cls.
#
# Auxiliary files (.aux/.log/etc.) go to a per-directory folder under
# ~/.cache/latexmk/ so they clutter neither the repo nor the output directory.
# The folder is keyed by the directory's repo-relative path (so two topics'
# same-named subdirectories never share latexmk state).
# Relies on the repo's .latexmkrc to put .course-machinery on TEXINPUTS.

set -uo pipefail

# Unwrap pdflatex's 79-column log lines so multi-line warnings keep their
# "on input line N" tails intact for log parsers -- vim's quickfix reads these
# logs (custom/vimtex.vim), and vimtex exports the same value for its own
# compiles. pdflatex picks the value up from the environment (kpathsea).
export max_print_line=2000

usage() {
  # Reprint the header block (line 2 to the first blank line), stripping the
  # leading "# ", so -h stays in sync with the comment above.
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
esac

# Parse a .OUTDIR file for its mirror base: blank and #-comment lines are ignored,
# an optional BOTH keyword and the bare base path may appear in either order, and
# `LABEL: path' named-destination lines are skipped here (resolve_label reads
# those). Echoes two lines — the mode (MOVE or BOTH) then the base path (a leading
# ~ expanded) — or warns and echoes nothing if the file names no base at all.
# VALIDATING the base is the caller's job (read_outdir requires it to exist; it
# creates the mirror sub-directory itself). (COPY, a songsheets synonym for BOTH,
# is intentionally not recognised here yet.)
parse_dest_file() {
  local f=$1 line trimmed lower path="" mode="MOVE"
  while IFS= read -r line || [[ -n $line ]]; do
    # Trim surrounding whitespace (covers a trailing CR too).
    trimmed=${line#"${line%%[![:space:]]*}"}
    trimmed=${trimmed%"${trimmed##*[![:space:]]}"}
    [[ -z $trimmed || ${trimmed:0:1} == "#" ]] && continue   # blank / comment
    lower=${trimmed,,}
    if [[ $lower == both ]]; then
      mode="BOTH"                  # keep a local copy too
      continue
    fi
    # A `LABEL: path' line is a named view destination, resolved separately by
    # resolve_label -- never the bare mirror-base path.
    [[ $trimmed =~ ^[A-Za-z0-9_-]+:[[:space:]] ]] && continue
    [[ -z $path ]] && path=$trimmed  # first non-keyword line = path
  done <"$f"

  if [[ -z $path ]]; then
    echo "build-pdfs: $f has no directory path, building locally" >&2
    return 0
  fi
  printf '%s\n%s\n' "$mode" "${path/#\~/$HOME}"
}

# Echo the path of the .OUTDIR governing the cwd: the nearest ancestor holding a
# .OUTDIR (the repo top level, the way .latexmkrc finds .course-machinery), or
# also its own root when found. Echoes two lines — the .OUTDIR file path then the
# directory that holds it — or nothing when no .OUTDIR exists above. Shared by the
# mirror resolver and the label resolver so both agree on which .OUTDIR is in force.
find_outdir_file() {
  local root=$PWD
  while [[ $root != / && ! -f $root/.OUTDIR ]]; do
    root=$(dirname -- "$root")
  done
  [[ -f $root/.OUTDIR ]] || return 0
  printf '%s\n%s\n' "$root/.OUTDIR" "$root"
}

# Resolve the mirror directory from the governing top-level .OUTDIR file. Reads a
# base directory from it (first bare non-comment line; a leading ~ expands; an
# optional BOTH line keeps a local copy too). The PDF ships to the base with the
# cwd's path relative to the .OUTDIR's own directory appended, so
# REPO/integrals/lectures mirrors to BASE/integrals/lectures. That mirror sub-
# directory is created if missing, but the base itself must exist — if it doesn't,
# warn and build locally rather than materialising a stray tree. Echoes two lines
# (mode, dest) on success, or nothing when the caller should build locally.
read_outdir() {
  local finfo f root info base mode rel dest
  finfo=$(find_outdir_file)
  [[ -n $finfo ]] || return 0          # no .OUTDIR anywhere above -> build locally
  { read -r f; read -r root; } <<<"$finfo"

  info=$(parse_dest_file "$f")
  [[ -n $info ]] || return 0
  { read -r mode; read -r base; } <<<"$info"
  if [[ ! -d $base ]]; then
    echo "build-pdfs: .OUTDIR base '$base' is not a directory, building locally" >&2
    return 0
  fi

  # Mirror the cwd's path relative to the .OUTDIR's directory under the base.
  rel=${PWD#"$root"}; rel=${rel#/}
  dest=$base${rel:+/$rel}
  if ! mkdir -p -- "$dest"; then
    echo "build-pdfs: could not create .OUTDIR path '$dest', building locally" >&2
    return 0
  fi
  printf '%s\n%s\n' "$mode" "$dest"
}

# Resolve a named view destination from the governing .OUTDIR: find the first
# `LABEL: path' line whose label matches $1, expand a leading ~, and require the
# path to be an existing directory. Echoes the directory on success, or warns and
# echoes nothing (no .OUTDIR, no such label, or the path is missing / not a
# directory) so the caller skips that one flat copy without failing the build.
resolve_label() {
  local label=$1 finfo f root line trimmed path
  finfo=$(find_outdir_file)
  if [[ -z $finfo ]]; then
    echo "build-pdfs: view label '$label' needs a .OUTDIR, skipping extra copy" >&2
    return 0
  fi
  { read -r f; read -r root; } <<<"$finfo"

  while IFS= read -r line || [[ -n $line ]]; do
    trimmed=${line#"${line%%[![:space:]]*}"}
    trimmed=${trimmed%"${trimmed##*[![:space:]]}"}
    [[ $trimmed == "$label:"* ]] || continue
    path=${trimmed#"$label":}                       # strip 'LABEL:'
    path=${path#"${path%%[![:space:]]*}"}           # trim leading space
    path=${path%"${path##*[![:space:]]}"}           # trim trailing space
    path=${path/#\~/$HOME}
    break
  done <"$f"

  if [[ -z ${path:-} ]]; then
    echo "build-pdfs: view label '$label' not found in $f, skipping extra copy" >&2
    return 0
  fi
  if [[ ! -d $path ]]; then
    echo "build-pdfs: view label '$label' path '$path' is not a directory, skipping extra copy" >&2
    return 0
  fi
  printf '%s\n' "$path"
}

# Drop one built PDF, flat, into the .OUTDIR destination named by a view label.
# Additive: this is an extra copy on top of the mirror, never a replacement. A
# label that does not resolve (resolve_label already warned) is skipped, and a
# failed copy warns but does not abort the build.
#   $1 directory the built PDFs live in   $2 pdf filename   $3 view label
ship_label() {
  local pdfdir=$1 file=$2 label=$3 dest
  dest=$(resolve_label "$label")
  [[ -n $dest ]] || return 0
  if cp -- "$pdfdir/$file" "$dest/"; then
    echo "    -> $label: $file"
  else
    echo "build-pdfs: could not copy $file to '$dest' for label '$label'" >&2
  fi
}

# Aux-dir key for the current directory: its path RELATIVE TO THE REPO ROOT
# (the nearest ancestor holding .course-machinery, found the way .latexmkrc
# finds it), slashes flattened to '-'. The old key was the bare directory name,
# so same-named directories in different topics (differentiation/problems and
# curve-sketching/problems) shared one latexmk aux dir and cross-contaminated
# its state. Outside any repo, fall back to the bare name as before.
aux_key() {
  local root=$PWD rel
  while [[ $root != / && ! -d $root/.course-machinery ]]; do
    root=$(dirname -- "$root")
  done
  if [[ -d $root/.course-machinery ]]; then
    rel=${PWD#"$root"}; rel=${rel#/}
    printf '%s' "${rel:+${rel//\//-}}"
    [[ -n $rel ]] || printf 'repo-root'
  else
    printf '%s' "${PWD##*/}"
  fi
}

# Read requested views from a source's leading magic-comment block. Recognises
# lines of the form `%! views: a, b, c' (flexible spacing) and echoes one view
# token per line. Scanning stops at the first line that is neither blank nor a
# `%'-comment, so only the leading block (before \documentclass) is consulted.
read_views() {
  local file=$1 line val tok toks
  while IFS= read -r line; do
    # First real (non-blank, non-comment) line ends the magic-comment block.
    if [[ -n $line && ${line#\%} == "$line" ]]; then
      break
    fi
    if [[ $line =~ ^%![[:space:]]*views[[:space:]]*:[[:space:]]*(.*)$ ]]; then
      val=${BASH_REMATCH[1]}
      IFS=',' read -ra toks <<<"$val"
      for tok in "${toks[@]}"; do
        # Trim surrounding whitespace.
        tok=${tok#"${tok%%[![:space:]]*}"}
        tok=${tok%"${tok##*[![:space:]]}"}
        [[ -n $tok ]] && printf '%s\n' "$tok"
      done
    fi
  done <"$file"
}

# Build a view of a document: inject a \def before \input to flip a class toggle,
# writing to a distinct -jobname so the view lands at its own PDF. Forced with -g
# because the source is unchanged, so latexmk's up-to-date check would otherwise
# skip the rebuild. The -pdflatex override reproduces the default invocation with
# the \def prepended (hence the nested quoting).
#   $1 jobname  $2 source  $3 auxdir  $4 jobname suffix
#   $5 injected TeX  $6 -outdir path (empty for a local build)
compile_view() {
  local jobname=$1 src=$2 auxdir=$3 suffix=$4 inject=$5 movedir=$6
  latexmk -pdf -g -auxdir="$auxdir" ${movedir:+"-outdir=$movedir"} -jobname="$jobname$suffix" \
    -pdflatex="pdflatex %O -interaction=nonstopmode \"$inject \\input{%S}\"" \
    "$src"
}

# Build one .tex file. Runs in a subshell so the cd stays local to this build.
build_file() {
  local src=$1 dir base jobname auxkey auxdir outinfo mode outdir movedir pdfdir
  local view name label suffix inject varaux
  dir=$(dirname -- "$src")
  base=$(basename -- "$src")
  jobname=${base%.tex}

  (
    # Compile in the source's own directory so the PDF lands next to the source
    # (latexmk's out-dir defaults to cwd) and the .latexmkrc there is picked up.
    cd "$dir" || exit
    auxkey=$(aux_key)
    auxdir="$HOME/.cache/latexmk/$auxkey-$jobname"
    mkdir -p "$auxdir" || exit

    # Output mirror: a governing top-level .OUTDIR mirrors the PDF to its base
    # tree (see header). read_outdir echoes two lines (mode, dest) or nothing.
    # MOVE (default): -outdir writes the PDF straight to the mirror. BOTH: build
    # locally (out-dir defaults to cwd), then copy the PDF to the mirror. movedir
    # carries the -outdir path for the MOVE case only, so BOTH keeps its local
    # build.
    mode=""; outdir=""; movedir=""
    outinfo=$(read_outdir)
    if [[ -n $outinfo ]]; then
      { read -r mode; read -r outdir; } <<<"$outinfo"
      if [[ $mode == BOTH ]]; then
        echo "    -> outdir: $outdir (local copy kept)"
      else
        movedir="$outdir"
        echo "    -> outdir: $outdir"
      fi
    fi

    latexmk -pdf -auxdir="$auxdir" ${movedir:+"-outdir=$movedir"} "$base" || exit
    echo "    ok: $jobname.pdf"
    if [[ $mode == BOTH ]]; then
      cp -- "$jobname.pdf" "$outdir/" || exit
    fi

    # Where the built PDFs actually live, for the flat `:LABEL' copies below: the
    # mirror dir in MOVE mode, else the local build dir (BOTH keeps a local copy;
    # no .OUTDIR builds locally).
    pdfdir="."; [[ -n $movedir ]] && pdfdir="$movedir"

    # Extra views requested via `%! views: ...' in the source's leading comment.
    # A view is just a jobname SUFFIX plus the \def(s) to inject -- the case sets
    # those two and one shared block below does the rest, so a new view is a
    # one-line arm. Each view gets its own aux dir (so it never clobbers the main
    # build's log) and follows the same MOVE/BOTH output handling as the default
    # build above. A `view:LABEL' token additionally drops a flat copy into the
    # named .OUTDIR destination; `default:LABEL' does the same for the base PDF.
    for view in $(read_views "$base"); do
      name=$view; label=""
      if [[ $view == *:* ]]; then name=${view%%:*}; label=${view#*:}; fi
      case $name in
        # The base PDF is already built; only a :LABEL does anything here.
        default)    [[ -n $label ]] && ship_label "$pdfdir" "$jobname.pdf" "$label"
                    continue ;;
        solutions)  suffix="-SOLUTIONS";  inject="\\def\\ShowSolutions{}" ;;
        hints)      suffix="-HINTS";      inject="\\def\\ShowHints{}" ;;
        projector)  suffix="-PROJECTOR";  inject="\\def\\ProjectorView{}" ;;
        # A view is a BUNDLE of content layers: instructor = solutions + hints
        # + the staff-notes tier (see InstructorNotes.sty's view model).
        instructor) suffix="-INSTRUCTOR"; inject="\\def\\ShowSolutions{}\\def\\ShowHints{}\\def\\ShowInstructorNotes{}" ;;
        *)
          echo "build-pdfs: view '$name' not yet supported, skipping" >&2
          continue
          ;;
      esac
      varaux="$HOME/.cache/latexmk/$auxkey-$jobname$suffix"
      mkdir -p "$varaux" || exit
      compile_view "$jobname" "$base" "$varaux" "$suffix" "$inject" "$movedir" || exit
      echo "    + $jobname$suffix.pdf ($name)"
      if [[ $mode == BOTH ]]; then cp -- "$jobname$suffix.pdf" "$outdir/" || exit; fi
      # An `if' (not `&&') so a label-less view leaves exit status 0 -- this is
      # the loop's (and so the subshell's) last statement, and a trailing false
      # here would make build_file wrongly report the whole file FAILED.
      if [[ -n $label ]]; then ship_label "$pdfdir" "$jobname$suffix.pdf" "$label"; fi
    done
  )
}

# Collect the files to build: explicit arguments, or every *.tex in cwd.
if [[ $# -gt 0 ]]; then
  files=("$@")
else
  shopt -s nullglob
  files=(*.tex)
  shopt -u nullglob
fi

if [[ ${#files[@]} -eq 0 ]]; then
  echo "build-pdfs: no .tex files found" >&2
  exit 1
fi

failed=()
for src in "${files[@]}"; do
  if [[ ! -f $src ]]; then
    echo "build-pdfs: skipping '$src' (not a file)" >&2
    failed+=("$src")
    continue
  fi
  echo "==> $src"
  if ! build_file "$src"; then
    echo "build-pdfs: FAILED on '$src'" >&2
    failed+=("$src")
  fi
done

if [[ ${#failed[@]} -gt 0 ]]; then
  echo "build-pdfs: ${#failed[@]} of ${#files[@]} failed: ${failed[*]}" >&2
  exit 1
fi
