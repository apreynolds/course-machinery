\ProvidesPackage{InstructorNotes}[2026/07/17 instructor-only notes layer]

%%% ===========================================================================
%%% InstructorNotes -- the INSTRUCTOR-NOTES content layer: \InstructorInline
%%% (inline), InstructorBox (block), \InstructorMargin (margin). All gated on
%%% \ifinstructornotes and FULLY GOBBLED when off, so a student build never
%%% carries a byte of them.
%%%
%%% (Named InstructorNotes, matching the flag it owns, \ShowInstructorNotes --
%%% NOT "Annotations", which reads as pencil mark-up of the notes on a tablet.)
%%%
%%% Why a shared .sty (loaded by LectureNotes + CourseDocument, not a class macro):
%%% both lectures and course documents carry instructor-only content -- notes-to-self,
%%% co-teacher asides -- and both want the instructor-copy page frame below.
%%% (Assessment.cls has neither yet.)
%%%
%%% VIEW MODEL: a "view" is a bundle of content layers. This package owns the
%%% \ShowInstructorNotes layer. The build's `instructor' view injects the bundle
%%% (\ShowSolutions + \ShowHints + \ShowInstructorNotes), so the instructor copy
%%% shows solutions, hints, and the slate staff notes.
%%%
%%% CONTRACT (load order): amsthm/amsmath must already be loaded (newtxmath via
%%% Typefaces owns that ordering), so REQUIRE InstructorNotes AFTER Typefaces. It
%%% pulls in tcolorbox itself (CourseDocument loads neither CourseBoxes nor
%%% tcolorbox); loading tcolorbox[most] a second time is a safe no-op.
%%% ===========================================================================

% Enforce the CONTRACT above loudly: tcolorbox drags amsmath in, so it must not
% be this package that first loads it -- newtxmath (via Typefaces) owns that order.
\@ifpackageloaded{newtxmath}{}{%
  \PackageError{InstructorNotes}
    {newtxmath is not loaded -- InstructorNotes must come AFTER Typefaces}
    {Load Typefaces (which sets up amsmath + newtxmath in the required
     order) before InstructorNotes, as the course classes do.}}

\RequirePackage[most]{tcolorbox}   % the note boxes
\RequirePackage{environ}           % \NewEnviron: drop a block's body when off
\RequirePackage{marginnote}        % \marginnote: margin placement without floating

%%% --- The layer flag (same idiom as Exercises.sty / ProblemMeta.sty) ---------
%%% ONE staff-notes tier (collapsed 2026-07-20; the earlier private/marker split
%%% was dropped -- see NOTE.md). \ShowInstructorNotes gates all staff notes; the
%%% instructor copy IS the staff copy, so everything a non-student may see lives
%%% in this one tier. Anything genuinely unfit for a TA simply stays out of the
%%% source.
\newif\ifinstructornotes
\ifdefined\ShowInstructorNotes \instructornotestrue \fi

%%% --- Colour (named once; house rule). SLATE, not a hue: instructor/marker
%%% content is "editorial / behind the scenes", so a neutral value reads right and
%%% competes with none of the student palette (red/blue/orange) or green=solutions.
%%% #334155 is a blue-slate (nudged blue so it isn't the plain Gray of the theorem
%%% rule); 10.4:1 on white AND carries white text at 10.4:1; !8 is the pale fill.
\definecolor{InstructorInk}{HTML}{334155}

%%% --- inline note: a WRAPPING slate run-in (no box, so it breaks across lines).
%%% Prefer InstructorBox / \InstructorMargin in general: a box or a margin note is
%%% unmistakable at a glance, whereas an inline run-in blends into the prose. Reach
%%% for inline only for a quick in-flow aside; anything you'll want to FIND again
%%% belongs in a box or the margin.
%%% (No \ignorespaces here, unlike the box/margin: this is running text, and eating
%%% the trailing space would fuse the note into the next word when the layer is on.)
\newcommand\InstructorInline[1]{%
  \ifinstructornotes{\sffamily\color{InstructorInk}#1}\fi
}

%%% --- slate SIDE-BAR notes. No title box, no tt (reserved for problem metadata).
%%% A wide slate bar sits in the LEFT MARGIN -- drawn by the overlay, so the box
%%% body keeps text width and aligns with the prose -- with a word rotated 90
%%% inside it. THREE environments, one look; the WORD differentiates, not the
%%% colour (slate == staff / behind-the-scenes, one meaning):
%%%   \begin{InstructorBox}          -> "note"    staff  (teaching cue)
%%%   \begin{InstructorBox}[marking] -> "marking" staff  (grading guidance)
%%% \NewEnviron so the body is DROPPED when the tier's flag is off. The word is
%%% centred on the box height via the overlay (which adds no height), so a very
%%% SHORT box with a LONG word can spill -- moot in practice. Bar 6mm; node xshift
%%% is half that.
% Zero-height overlay routing. Workspace.sty (loaded by Assessment/LectureNotes) defines
% \WSZeroHeight -- in the default OVERLAY mode it emits the box at zero height so it
% paints down into the reserved \workspace instead of shifting the layout; under
% \solidboxes it emits normally. InstructorNotes stays self-contained: this
% \AtBeginDocument fallback makes \WSZeroHeight a pass-through when Workspace is
% absent (e.g. under CourseDocument, which loads this package but no \workspace), so
% the box just renders at normal height there.
\AtBeginDocument{\providecommand{\WSZeroHeight}[1]{#1}}

\newcommand\instr@sidebar[1]{% #1 = the rotated bar word; body is \BODY
  \WSZeroHeight{\begin{tcolorbox}[enhanced, breakable, parbox=false,
    frame hidden, boxrule=0pt, sharp corners,
    colback=InstructorInk!8,
    left=8pt, right=8pt, top=8pt, bottom=8pt,
    overlay={%
      \fill[InstructorInk]
        ([xshift=-6mm]frame.south west) rectangle (frame.north west);
      \node[white, rotate=90, font=\sffamily\bfseries\scriptsize]
        at ([xshift=-3mm]frame.west) {#1};
    }]
    \sffamily\BODY
  \end{tcolorbox}}%
}
\NewEnviron{InstructorBox}[1][note]{\ifinstructornotes\instr@sidebar{#1}\fi}

%%% --- margin note: slate bold sans in the margin (unified with the layer) -----
\newcommand\InstructorMargin[1]{%
  \ifinstructornotes
    \marginnote{\color{InstructorInk}\sffamily\bfseries\raggedright #1}%
  \fi
  \ignorespaces
}

%%% --- "Instructor copy" page frame -------------------------------------------
%%% A slate frame just inside every page edge, with a small "Instructor copy" tab
%%% tucked into the BOTTOM-RIGHT corner, sitting on the frame line. Bottom-right,
%%% not bottom-centre, so it clears the centred page-number footer both the lecture
%%% and assessment classes carry (centred tab + centred footer collided). This
%%% REPLACES a title stamp (seen only on page 1) and a diagonal watermark (which
%%% fights the content): an ever-present, low-distraction marker. Drawn via eso-pic's
%%% shipout background -- NO tikz, so no remember-picture two-pass -- and loaded ONLY
%%% for the instructor view, so student builds never pull eso-pic in.
\ifinstructornotes
  \RequirePackage{eso-pic}
  % --- TWEAK HERE: the two knobs for the instructor-copy frame ----------------
  \newcommand\InstructorFrameInset{2.5mm}% gap from the page edge to the frame
  \newcommand\InstructorFrameRule{1.5mm}%  frame line thickness
  \AddToShipoutPictureBG{%
    \put(\LenToUnit{\InstructorFrameInset},\LenToUnit{\InstructorFrameInset}){%
      \color{InstructorInk}\linethickness{\InstructorFrameRule}%
      \framebox(\LenToUnit{\dimexpr\paperwidth-\InstructorFrameInset-\InstructorFrameInset\relax},%
                \LenToUnit{\dimexpr\paperheight-\InstructorFrameInset-\InstructorFrameInset\relax}){}%
    }%
    \put(\LenToUnit{\dimexpr\paperwidth-\InstructorFrameInset-5mm\relax},\LenToUnit{\InstructorFrameInset}){%
      \makebox(0,0)[r]{\colorbox{white}{%
        \color{InstructorInk}\sffamily\bfseries\footnotesize\,Instructor copy\,}}%
    }%
  }%
\fi

\endinput
