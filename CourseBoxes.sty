\ProvidesPackage{CourseBoxes}[2026/07/16 declared-number theorem boxes + asides]

%%% ===========================================================================
%%% CourseBoxes -- tcolorbox-styled theorem-like environments in two families:
%%%
%%%   TEXT RESULTS (category A) -- things that live in the primary TEXT and carry
%%%     the number the text gives them. The number is DECLARED (typed), not
%%%     counted: \begin{theorem}{2.1.3}[Power Rule]. \label/\ref work, but no
%%%     LaTeX counter is involved, so the machinery is numbering-scheme-agnostic
%%%     -- a shared-counter text, a separate-counter text, and a skip-heavy text
%%%     all just work, because nothing here counts. (Mechanism and rationale:
%%%     manual/ch-architecture.tex, "Declared numbers".)
%%%
%%%   ASIDES (category B) -- MY pedagogical interjections (Key Idea, Tip,
%%%     Caution). Unnumbered, and deliberately NOT \label-able: references point
%%%     at the primary text, not at my notes. A stray \label fails LOUD (prints
%%%     "[unlabelled aside]") rather than silently grabbing the section number.
%%%
%%% This file ships the FACTORY plus a UNIVERSAL default vocabulary. Text-specific
%%% names (Key Idea, Axiom, ...) are declared in the course's own TEXT LAYER
%%% (.textbook/textbook.tex), \input from the master's preamble -- NOT here (this
%%% is the shared submodule; a single text's vocabulary is not shared).
%%%
%%% CONTRACT (load order):
%%%   - amsthm must ALREADY be loaded. In our classes newtxmath's [amsthm] option
%%%     owns that (via Typefaces), so REQUIRE CourseBoxes AFTER Typefaces and do
%%%     NOT let it pull amsthm in (that would refight the load-order fixed in
%%%     "Fonts").
%%%   - hyperref must be loaded by the time a box is USED (for \phantomsection).
%%%     Hyperlinks.sty defers it to \AtEndPreamble, which is in time -- the boxes
%%%     are only ever used in the body.
%%% ===========================================================================

% Enforce the CONTRACT above loudly: amsthm arrives via newtxmath's [amsthm]
% option (i.e. via Typefaces); loading this package first would otherwise fail
% at the first \newtheoremstyle with a cryptic error.
\@ifpackageloaded{amsthm}{}{%
  \PackageError{CourseBoxes}
    {amsthm is not loaded -- CourseBoxes must come AFTER Typefaces}
    {Load Typefaces (whose newtxmath pulls amsthm in at the right moment)
     before CourseBoxes, as the course classes do.}}

\RequirePackage[most]{tcolorbox}     % \tcolorboxenvironment, enhanced, breakable
\RequirePackage{fontawesome5}        % topic glyphs + expressive faces (pdflatex-safe,
                                     % monochrome, inherit surrounding colour). NOT
                                     % wasysym: that redefines math symbols newtxmath
                                     % owns. Colour emoji would need lualatex; we don't.

%%% --- Colours (named once; house rule). PROVISIONAL -- the colour-blind-safe
%%% palette is still an open conversation; these are placeholders so the icons can
%%% be judged. Red/blue/orange is already the safe backbone; the icons below are
%%% the colour-independent channel that make the orange-next-to-red pair robust.
%%% "named" needs dvipsnames, which the class passes to xcolor before it loads.
\definecolor{ThmColor}{named}{Gray}        % text results: understated grey rule
\definecolor{NoteColor}{named}{RoyalBlue}  % informational asides (blue family)
\definecolor{CautionColor}{named}{Red}     % Caution -- the lone alarm colour
\definecolor{TipColor}{HTML}{E69F00}       % Tips -- Okabe-Ito orange (frame + fill)
\definecolor{TipTextColor}{HTML}{B36B00}   % Tips -- darker orange for HEAD TEXT only:
                                           % #E69F00 as text is 2.25:1 on white (fails
                                           % WCAG); #B36B00 is 4.18:1. Light fill, dark
                                           % text -- the frame/fill stay TipColor.

%%% --- tcolorbox styles (named once; the extension point). --------------------
%%% A course's text layer references these by name, so restyling every Theorem in
%%% the course is a one-line edit here.
\tcbset{
  cb/textresult/.style={          % category A: thin grey L-rule, textbook-quiet
    enhanced, breakable, frame hidden, colback=white,
    sharp corners, top=6pt, left=8pt, right=8pt,
    borderline west ={0.5pt}{0pt}{ThmColor},
    borderline north={0.5pt}{0pt}{ThmColor},
  },
  cb/note/.style={                % category B: solid blue box (Key Idea / Tip)
    enhanced, breakable, colback=NoteColor!4, colframe=NoteColor,
    sharp corners, boxrule=2pt,
  },
  cb/caution/.style={             % category B: solid red box (Caution)
    enhanced, breakable, colback=CautionColor!4, colframe=CautionColor,
    sharp corners, boxrule=2pt,
  },
  cb/tip/.style={                 % category B: solid orange box (Tip tiers)
    enhanced, breakable, colback=TipColor!6, colframe=TipColor,
    sharp corners, boxrule=2pt,
  },
}

%%% --- amsthm head styles (the DECLARED trick + the head knob). ---------------
%%% ONE shared head spec across every style: {\thmname{#1}\thmnote{ #3}}. It omits
%%% the number slot (#2) entirely -- no counter to print -- and renders the note
%%% bare. A text result's wrapper puts "num (name)" in the note; an aside passes
%%% no note, and amsthm suppresses \thmnote when the note is empty, so the very
%%% same spec prints just the name. That is what makes the head a free knob: the
%%% styles below differ ONLY in body font + head font/colour, and any of them can
%%% dress either a numbered result or an unnumbered aside.
%%%
%%%   cbthm     italic body, bold serif head        (theorem/prop/lemma/corollary)
%%%   cbdefn    upright body, bold serif head        (definition/example/remark)
%%%   cbaside   upright body, sans-bold black head    (generic aside)
%%%   cbnote    upright body, sans-bold BLUE head     (Key Idea, Takeaway, Prepwork)
%%%   cbnotecolon as cbnote but a COLON head-punct    (Your turn:)
%%%   cbcaution upright body, sans-bold RED head      (Caution)
%%%
%%% HEAD PUNCTUATION is the 6th \newtheoremstyle arg -- the {.} / {:} after the
%%% head font. Change it to switch a style's punctuation (e.g. to {!}).
\newtheoremstyle{cbthm}
  {\topsep}{\topsep}{\itshape}{}{\bfseries}{.}
  {5pt plus 1pt minus 1pt}{\thmname{#1}\thmnote{ #3}}
\newtheoremstyle{cbdefn}
  {\topsep}{\topsep}{}{}{\bfseries}{.}
  {5pt plus 1pt minus 1pt}{\thmname{#1}\thmnote{ #3}}
\newtheoremstyle{cbaside}
  {\topsep}{\topsep}{}{}{\sffamily\bfseries}{.}
  {.5em}{\thmname{#1}\thmnote{ #3}}
\newtheoremstyle{cbnote}
  {\topsep}{\topsep}{}{}{\sffamily\bfseries\color{NoteColor}}{.}
  {.5em}{\thmname{#1}\thmnote{ #3}}
\newtheoremstyle{cbnotecolon}%                    <-- head punct ":" (Your turn:)
  {\topsep}{\topsep}{}{}{\sffamily\bfseries\color{NoteColor}}{:}
  {.5em}{\thmname{#1}\thmnote{ #3}}
\newtheoremstyle{cbcaution}%                       <-- head punct ":" (CAUTION:)
  {\topsep}{\topsep}{}{}{\sffamily\bfseries\color{CautionColor}}{:}
  {.5em}{\thmname{#1}\thmnote{ #3}}
\newtheoremstyle{cbtip}%                           <-- head punct: change {:} to {!} etc.
  {\topsep}{\topsep}{}{}{\sffamily\bfseries\color{TipTextColor}}{:}
  {.5em}{\thmname{#1}\thmnote{ #3}}

%%% --- The factories ----------------------------------------------------------
%%% \NewTextResult[amsthm-style]{env}{Display Name}{tcb style}
%%%   Default style is cbdefn (upright); pass [cbthm] for an italic-bodied result.
%%%   Call site: \begin{env}{number}[optional name].
%%%
%%% Mechanics: \phantomsection and the
%%% \@currentlabel assignment run in the BEGIN CODE, before \begin{cb@env}, i.e.
%%% OUTSIDE the tcolorbox -- which is exactly why layout (tcolorbox) and mechanics
%%% (the label) do not interfere.
\NewDocumentCommand{\NewTextResult}{O{cbdefn} m m m}{%
  \theoremstyle{#1}%
  \newtheorem*{cb@#2}{#3}%                 % base: starred = no counter
  \tcolorboxenvironment{cb@#2}{#4}%        % box the base
  \NewDocumentEnvironment{#2}{m o}{%
    \phantomsection
    \protected@edef\@currentlabel{##1}%    % \label will record the typed number
    \IfValueTF{##2}{\begin{cb@#2}[##1 (##2)]}{\begin{cb@#2}[##1]}%
  }{%
    \end{cb@#2}%
  }%
}

%%% \NewAside[head style]{env}{Display Name}{tcb style}
%%%   Unnumbered. Default head is cbaside (black); pass [cbnote]/[cbcaution]/... to
%%%   colour it. The sentinel \@currentlabel makes a stray \label print
%%%   "[unlabelled aside]" -- loud, not the silent section-number leak.
\NewDocumentCommand{\NewAside}{O{cbaside} m m m}{%
  \theoremstyle{#1}%
  \newtheorem*{cb@#2}{#3}%
  \tcolorboxenvironment{cb@#2}{#4}%
  \NewDocumentEnvironment{#2}{}{%
    \protected@edef\@currentlabel{[unlabelled aside]}%
    \begin{cb@#2}%
  }{%
    \end{cb@#2}%
  }%
}

%%% --- Universal default vocabulary -------------------------------------------
%%% Present in every text; not course-specific, so it ships here. A course adds
%%% only its text-specific extras in its text layer (Key Idea, Axiom, ...).
\NewTextResult[cbthm]{theorem}    {Theorem}    {cb/textresult}
\NewTextResult[cbthm]{proposition}{Proposition}{cb/textresult}
\NewTextResult[cbthm]{lemma}      {Lemma}      {cb/textresult}
\NewTextResult[cbthm]{corollary}  {Corollary}  {cb/textresult}
\NewTextResult      {definition} {Definition} {cb/textresult}
\NewTextResult      {example}    {Example}    {cb/textresult}
\NewTextResult      {remark}     {Remark}     {cb/textresult}

%%% --- Shared pedagogical asides (MY voice, consistent course-to-course) -------
%%% These are the instructor's interjections, not the text's, so they ship here
%%% (shared) rather than in the text layer. A fontawesome glyph in the head inherits
%%% the head colour and is the colour-independent cue -- kept on Caution / Your Turn
%%% / Prepwork, dropped on Takeaway.
%%%
%%% "Check In" is NO LONGER an aside here. A check-in is now an imported
%%% multiple-choice problem (\importcheckin, in Exercises.sty): a neutral titled
%%% box whose choice labels are the colored A/B/C flashcard boxes. The old prose
%%% \begin{checkin} aside is retired.
\NewAside[cbcaution]  {caution} {\faExclamationTriangle\ CAUTION}{cb/caution}
\NewAside[cbnote]     {takeaway}{TAKEAWAY}                       {cb/note}
\NewAside[cbnotecolon]{yourturn}{\faPenFancy\ Your turn}        {cb/note}
\NewAside[cbnote]     {prepwork}{\faBookOpen\ Prepwork}          {cb/note}

%%% Tip -- a shared aside with an OPTIONAL audience tier. \begin{tip} is neutral;
%%% [surviving] / [thriving] append "for the <tier>" to the head. Built by hand
%%% (not via \NewAside) because the head text varies per call: \cb@tiphead is set
%%% in the begin-code, so amsthm expands it late, at head-render time.
\def\cb@survkey{surviving}
\def\cb@thrivkey{thriving}
\providecommand\cb@tiphead{Tip}          % safe default if cb@tip is used bare
\theoremstyle{cbtip}
\newtheorem*{cb@tip}{\cb@tiphead}
\tcolorboxenvironment{cb@tip}{cb/tip}
\NewDocumentEnvironment{tip}{O{}}{%
  \protected@edef\@currentlabel{[unlabelled aside]}%
  \def\cb@tiphead{Tip}%
  \def\cb@aud{#1}%
  \ifx\cb@aud\cb@survkey  \def\cb@tiphead{Tip for the \textit{surviving}}\fi
  \ifx\cb@aud\cb@thrivkey \def\cb@tiphead{Tip for the \textit{thriving}}\fi
  \begin{cb@tip}%
}{%
  \end{cb@tip}%
}

\endinput
