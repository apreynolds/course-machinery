#!/usr/bin/env bash
# pick-problems — fzf picker over the problem bank; emits \importproblem lines
# Usage: pick-problems [--from DIR] [FILTER ...] [PATH ...]
#
# An interactive front-end to find-problems. It feeds `find-problems --tsv' into
# fzf (multi-select, metadata shown, the .tex previewed), then turns the chosen
# problems into paste-ready \importproblem lines via `find-problems --import'.
# The import block is printed to stdout -- pipe it, or paste it into a document.
#
#   --from DIR    make the emitted directory arguments relative to DIR (the
#                 folder of the document you will paste into); handed straight to
#                 find-problems --import. Without it, paths are relative to the
#                 search root and usually need a ../ or two.
#
# Every other argument is forwarded verbatim to `find-problems --tsv', so all of
# its filters (--topic, --type, --difficulty, --source) and PATH operands work
# here too, to pre-narrow what the picker offers -- e.g.
#
#   pick-problems --from _assessment --type multiple-choice derivatives/
#
# In the picker: Tab marks/unmarks a row, Enter accepts the marked set (or the
# highlighted row if none are marked), Esc cancels. points= is never filled in
# (it is extrinsic) -- add it to the pasted lines by hand.

set -uo pipefail

usage() {
  # Reprint the header block (line 2 to the first blank line), stripping the
  # leading "# ", so -h stays in sync with the comment above -- as find-problems
  # and build-pdfs do.
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
}

# find-problems is our sibling in the same directory. Call it by path rather than
# assume it is on PATH: it is not installed globally -- each course carries its
# own copy in .course-machinery, and that is the one we want.
here=$(cd -- "$(dirname -- "$0")" && pwd)
fp="$here/find-problems"
if [[ ! -x $fp ]]; then
  echo "pick-problems: cannot find find-problems next to me ($fp)" >&2
  exit 2
fi

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# ARGUMENTS
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Pull out --from (which only --import understands); forward everything else --
# find-problems' own filters and PATH operands -- to the --tsv feed.
from=""
feed_args=()
while [[ $# -gt 0 ]]; do
  case $1 in
    -h | --help) usage; exit 0 ;;
    --from)      from=${2:?--from needs a directory}; shift 2 ;;
    *)           feed_args+=("$1"); shift ;;
  esac
done

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# PICK
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Column 1 (the path) is hidden from the display (--with-nth=2..) but is what the
# preview reads ({1}) and what we hand back to --import; search covers the shown
# metadata. fzf exits non-zero on cancel or no-match, so we do not `set -e' and
# just treat an empty result as "nothing to do".
selection=$(
  "$fp" --tsv "${feed_args[@]}" \
    | fzf --multi \
          --delimiter='\t' --with-nth=2.. \
          --preview='bat --color=always --language=tex --style=numbers {1}' \
          --preview-window='right:60%' \
          --prompt='problem> '
)
[[ -z $selection ]] && exit 0

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# EMIT
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Recover the paths (column 1) and hand exactly those files to the one emitter,
# so the \importproblem construction, #-escaping and --from logic all live in
# find-problems, never duplicated here.
mapfile -t files < <(printf '%s\n' "$selection" | cut -f1)

import_args=(--import --with number,desc)
[[ -n $from ]] && import_args+=(--from "$from")

"$fp" "${import_args[@]}" "${files[@]}"
