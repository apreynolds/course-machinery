#!/usr/bin/env bash
# pick-problems — fzf picker over the problem bank; emits \importproblem lines.
# A thin shim over pick-meta (the shared picker). Forwards find-problems' filters
# and PATH operands; `--from DIR' makes emitted paths relative to DIR. See
# pick-meta and find-problems.
exec "$(dirname -- "$0")/pick-meta" --kind problem --as pick-problems "$@"
