\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{Hyperlinks}[2026/07/22 hyperref (loaded last) + back-to-top anchor + \string\demo]

% hyperref for the course classes, plus the anchor a back-to-top link jumps to,
% plus \demo (links out to an interactive tool).
%
% Requires the loading class to have done, before \ProcessOptions:
%     \PassOptionsToPackage{dvipsnames}{xcolor}
% (named colours below need it, and xcolor's options must be set before anything
% else pulls xcolor in).

\RequirePackage{etoolbox} % \AtEndPreamble
\RequirePackage{xcolor}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PER-CLASS HOOKS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Same pattern as Titling.sty: defaults are the plain/lecture ones; a class
% overrides with \renewcommand before \begin{document}. They are read inside the
% \AtEndPreamble block below, i.e. late, so an override anywhere in the class or
% the document's preamble still wins.
\providecommand{\LinkColor}{black}
\providecommand{\UrlColor}{RoyalBlue}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HYPERREF -- LOADED LAST
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% hyperref patches a great deal of LaTeX (\ref, sectioning, \tableofcontents,
% amsthm...), so anything loaded AFTER it can silently undo those patches. It
% must therefore load after every package the DOCUMENT loads, not merely after
% this class -- which is what \AtEndPreamble gives and \AtEndOfClass does not.
\AtEndPreamble{%
  \RequirePackage{hyperref}%
  \hypersetup{%
    colorlinks    = true,%
    linkcolor     = \LinkColor,%
    citecolor     = black,%
    urlcolor      = \UrlColor,%
    pdfstartview  = Fit,%
    pdfmenubar    = true,%
    pdftoolbar    = true,%
    bookmarksopen = false,%
  }%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% BACK-TO-TOP ANCHOR
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% The destination a back-to-top link jumps to: the very top of the body, which is
% also where a \tableofcontents sits when the document has one.
%
% Emitted at \AtBeginDocument -- deliberately, not earlier: \hypertarget needs
% hyperref, which does not exist until the \AtEndPreamble above has run, and
% \AtEndPreamble fires before any \AtBeginDocument hook.
%
% \BackToTopLink{<stuff>} wraps its argument in the jump. Kept separate from any
% styling so the caller decides what the link looks like -- LectureNotes uses a
% grey arrow in the projector footer; nothing else uses it yet.
\newcommand{\TopAnchorName}{CourseTop}
\AtBeginDocument{\hypertarget{\TopAnchorName}{}}
\newcommand{\BackToTopLink}[1]{\hyperlink{\TopAnchorName}{#1}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \demo -- LINK OUT TO AN INTERACTIVE TOOL
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%   \demo{https://www.desmos.com/calculator/xxxxxxxx}
%   \demo[geogebra]{https://example.org/some/opaque/url}
%
% THE PRINCIPLE: students do not care which tool it is -- only the author does.
% A class that meets "LINK: DESMOS", "Desmos demo" and "LET'S EXPLORE WITH
% DESMOS!" on three consecutive pages is reading three different things when it
% is always the same thing: press here, a graph moves. So every demo gets ONE
% student-facing label, and the tool's identity is author-only metadata.
%
% Hence the optional argument is ACCEPTED AND DISCARDED (the same store-only
% idiom as ProblemMeta/FactMeta): it names the tool for a human reader of the
% source, and for the eventual link-checker, which classifies a link by its URL
% domain and needs the hint only when the domain is opaque. Nothing about it
% reaches the page.
%
% The real payoff is enumerability. Every demo routed through one macro means
% "curl all my interactive links and tell me which died over the summer" is a
% grep away -- rot found on your schedule, not in front of a class. That is why
% even a bare \href you were about to write should be a \demo.
%
% Lives here rather than in TextRef.sty deliberately: a demo link has nothing to
% do with the textbook (it is your own Desmos page as often as not), and
% Hyperlinks is loaded by both LectureNotes and CourseDocument, so \demo works
% in a syllabus too. Assessment loads no hyperref -- correctly, since a link on
% printed paper is a dead end -- and therefore has no \demo.

% Knobs. The marker is \triangleright rather than the heavier \blacktriangleright
% because the latter is an amssymb symbol and this package deliberately requires
% no maths font (Assessment-adjacent classes may load neither).
\providecommand{\DemoLabel}{interactive graph}
\providecommand{\DemoMarker}{\ensuremath{\triangleright}}

% The whole rendering in one hook, so a course can restyle it (bracket it, put
% it on its own line, drop the marker) without touching the macro.
\providecommand{\DemoFormat}[1]{\href{#1}{\DemoMarker\,\DemoLabel}}

\NewDocumentCommand{\demo}{o m}{\DemoFormat{#2}}
