\ProvidesPackage{Exercises}[2026/07/16 problem/solution environments + the solutions toggle]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% WHAT THIS IS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% The roll-your-own exercise system -- the homegrown answer to NOTE.md item 4,
% built instead of resurrecting xsim. It provides:
%
%   \begin{problem} ... \end{problem}     numbered, cross-referenceable
%   \begin{problemgroup}{STEM} ...         "Problem N." + stem; parts render (a),(b)
%   \begin{solution} ... \end{solution}   printed only in the solutions build
%   \importproblem[POINTS]{DIR}{FILE}      \import a problem, points set HERE
%   \importproblem*[POINTS]{DIR}{FILE}     ... shown but NOT added to the total
%   \printtotalpoints                      the summed points of the assessment
%
% plus the \ifsolutions toggle that drives the solution environment. Deliberately
% small: a counter, two environments, one conditional, one import wrapper -- all
% LaTeX primitives, none of xsim's expensive machinery. See NOTE.md item 4 for
% why that boundary is safe.
%
% SELF-CONTAINED ON PURPOSE. This is the ESSENTIAL package -- problem sets with
% optionally-printed solutions, the thing the course cannot be taught without.
% It does NOT depend on ProblemMeta.sty (the tagging, which is nice-to-have): if
% ProblemMeta broke or were removed, everything here still works. The class loads
% the two separately. As a final safety, the \AtBeginDocument stub below lets a
% problem file that still contains a \ProblemMeta{...} block compile even when
% ProblemMeta is absent -- the block is silently swallowed.
%
% VOCABULARY NOTE: the package is "Exercises" (NOTE.md's name for the system),
% but the author-facing environment is \begin{problem} -- the word the content
% already uses and the one Patrick is accustomed to. The mismatch is intentional.

\RequirePackage{environ}       % \NewEnviron: capture a body to conditionally emit
\RequirePackage{etoolbox}      % \ifdefempty
\RequirePackage{import}        % \import, wrapped by \importproblem
\RequirePackage{totcount}      % \newtotcounter/\total: two-pass sum for \printtotalpoints

% Own the colour dependency rather than borrowing ProblemMeta's -- this package
% must stand alone. dvipsnames for the named colour below; consistent with the
% option ProblemMeta and the classes pass, so no clash.
\PassOptionsToPackage{dvipsnames}{xcolor}
\RequirePackage{xcolor}

% If ProblemMeta is not loaded, make \ProblemMeta a no-op that swallows its
% argument, so problem files carrying a metadata block still compile. Deferred to
% \AtBeginDocument so it is order-independent: if ProblemMeta IS loaded (before or
% after this package), its real definition already exists and \providecommand
% does nothing; problem files are only read in the body, so the stub is in place
% in time either way.
\AtBeginDocument{\providecommand{\ProblemMeta}[1]{}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SOLUTIONS TOGGLE
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Off by default (the student build). build-pdfs injects \def\ShowSolutions{} on
% the command line for the -SOLUTIONS twin (see its `%! views: solutions').
%
% This lived in Test.cls as scaffolding. Moved here so it is SHARED: a problem
% file that carries its own \begin{solution} can now be \import-ed into a LECTURE
% (LectureNotes) as well as a test, which it could not when only Test.cls knew
% the machinery. That was NOTE.md item 4's open gap; this closes it.
\newif\ifsolutions
\ifdefined\ShowSolutions \solutionstrue \fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% POINTS (set at import time, NOT in the problem file)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% A problem has no intrinsic point value -- it is worth 5 on one assessment, 7 on
% another. So points are EXTRINSIC: specified where the problem is imported, not
% stored with it. (Contrast ProblemMeta's tags/difficulty, which ARE intrinsic
% and live in the file.) \importproblem stashes the value; the problem
% environment prints it and clears it, so it attaches to exactly one problem and
% never leaks to the next.
\newcommand{\CurrentProblemPoints}{}

% Whether the current problem's points count toward the total. "1" = counted
% (the default); "0" = shown but off the books. Set by the star form of
% \importproblem, read (and reset) in the problem environment alongside points.
% Serves two cases with one mechanism: BONUS questions (extra, so out of the
% denominator) and CHOOSE-1-OF-N pairs (mark all but one of the alternatives
% off-the-books, so a 10-or-10 pair contributes 10, not 20). It deliberately does
% NOT alter the printed marker -- "choose one" pairs must still read "(10 points)"
% on both, and which case it is (bonus vs. choose) is carried by exam prose.
\newcommand{\CurrentProblemCounts}{1}

% How the points render next to the heading. Stylable in one place; the eventual
% target is the quarry's margin \fbox, but an inline marker is enough for now.
% \ifnum picks "point" vs "points" -- which is also why points must be an INTEGER
% (see \importproblem): \ifnum and the \addtocounter into the total both need one.
\newcommand{\ProblemPointsFormat}[1]{%
  \quad\textnormal{\normalfont(#1\ \ifnum#1=1 point\else points\fi)}}

% The assessment total. \newtotcounter registers a normal counter that totcount
% writes to the .aux at end-of-document; \total reads back the PREVIOUS run's
% final value, so \printtotalpoints is correct even at the TOP of the page (the
% usual "worth N points" line). First compile shows "??" and warns "Rerun ...";
% the aux changes, so latexmk reruns on its own. The counter is fed in the
% problem environment below, not here, so it counts problems that actually print.
\newtotcounter{totalpoints}
\newcommand{\printtotalpoints}{\total{totalpoints}}

% \importproblem[POINTS]{DIR}{FILE} -- \import with a point value attached here.
% The STARRED form \importproblem*[POINTS]{DIR}{FILE} shows the points but keeps
% them out of the total (bonus / choose-1-of-N; see \CurrentProblemCounts above).
% Bare \import still works and yields no marker (e.g. a lecture, ungraded). The
% trailing resets are a safety net for the odd file that sets no problem to
% consume the values; normally the environment below has already cleared them.
% \@ifstar dispatches to the two forms, which differ only in the count flag.
\newcommand{\importproblem}{\@ifstar\importproblem@off\importproblem@on}
\newcommand{\importproblem@on}[3][]{\importproblem@do{1}{#1}{#2}{#3}}
\newcommand{\importproblem@off}[3][]{\importproblem@do{0}{#1}{#2}{#3}}
% #1 = count flag, #2 = points, #3 = dir, #4 = file.
\newcommand{\importproblem@do}[4]{%
  \gdef\CurrentProblemCounts{#1}%
  \gdef\CurrentProblemPoints{#2}%
  \import{#3}{#4}%
  \gdef\CurrentProblemPoints{}\gdef\CurrentProblemCounts{1}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% A run-in bold heading "Problem N." then the body, matching the content's
% existing \textbf{Problem.} style but numbered, with the import-time points (if
% any) after it. \refstepcounter (not \stepcounter) so \label inside a problem
% points at the problem: \ref gives its number.
%
% The counter is flat and document-wide: each import of a problem file steps it,
% so a set of five imported problems numbers 1..5. To restart numbering per
% section, a document can \counterwithin{problem}{section}; to reset equation
% numbers per problem, \counterwithin{equation}{problem} -- neither is imposed
% here (they surprise as often as they help).
%
% The end code clears the points globally (\gdef): \import does not group its
% contents, but clearing globally is robust regardless and enforces consume-once.
\newcounter{problem}

% Grouped subquestions (see the PROBLEM GROUPS section). Inside a \problemgroup
% each imported problem renders as a lettered PART -- "(a)", "(b)" -- instead of
% "Problem N.". The flag below, set locally true by the group, is what the problem
% environment branches on; the same atomic file renders either way, so nothing in
% the library changes. The counter resets whenever `problem' steps (so each group,
% and each top-level problem, starts its letters at (a)); \p@subproblem makes a
% \ref to a part read "N(a)".
\newif\ifinproblemgroup
\newcounter{subproblem}[problem]
% \thesubproblem carries the parent number ("4(a)") so a \ref to a part reads
% "4(a)" -- the same nesting trick as \theequation under a section. The prefix
% must live INSIDE \thesubproblem, not in \p@subproblem: routed through \p@ the
% \number scan inside \arabic{problem} swallows the following token and the
% letter is lost. The heading prints just "(a)" via \alph directly (below), so the
% two representations differ on purpose -- short label on the page, full ref.
\renewcommand{\thesubproblem}{\theproblem(\alph{subproblem})}

% The heading branches on \ifinproblemgroup: a top-level problem is "Problem N.",
% a part is "(a)". The POINTS block is shared by both -- per-part points and the
% starred off-the-books form work identically inside a group. The points guard
% prints the marker whenever a value is present, but only adds to the running
% total when \CurrentProblemCounts is "1" (\addtocounter is global, so it survives
% \import's grouping and each problem contributes once). A file that declares no
% points contributes 0 and shows nothing.
\newenvironment{problem}{%
  \par
  \ifinproblemgroup
    \refstepcounter{subproblem}%
    \noindent\textbf{(\alph{subproblem})}%
  \else
    \refstepcounter{problem}%
    \noindent\textbf{Problem \theproblem.}%
  \fi
  % \refstepcounter sets \@currentlabel LOCALLY, but this environment is a group
  % and the problem body arrives via \import -- so a \label written next to the
  % \importproblem (outside the group) would otherwise capture the *enclosing*
  % label, not this problem's. Globalise it so \label works from the assembly
  % file. hyperref already makes its anchor (\@currentHref) global, so this keeps
  % the ref text and the hyperlink target in sync.
  \global\let\@currentlabel\@currentlabel
  \ifdefempty{\CurrentProblemPoints}{}{%
    \ifdefstring{\CurrentProblemCounts}{1}{\addtocounter{totalpoints}{\CurrentProblemPoints}}{}%
    \ProblemPointsFormat{\CurrentProblemPoints}%
  }%
  \quad\ignorespaces
}{\par\gdef\CurrentProblemPoints{}\gdef\CurrentProblemCounts{1}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM GROUPS (subquestions)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \begin{problemgroup}{STEM} ... \end{problemgroup} -- a numbered "Problem N."
% carrying a shared instruction (STEM), under which each imported problem prints
% as a lettered part (a), (b), .... This is the ASSEMBLY-TIME wrapper: the parts
% stay atomic one-problem files in the bank and are pulled in with \importproblem
% exactly as anywhere else; the group only changes how they render. Use it for
% independent items sharing an instruction ("Evaluate the following integrals:").
% Genuinely dependent parts ("Let f(x)=...; (a)... (b)...") are ONE problem and
% belong in one file -- not this.
%
% Points are per-part (each \importproblem[..] inside carries its own), so the
% group takes no point value; the grand total sums the parts as usual, and a part
% may be starred (\importproblem*) to sit off the books.
%
% Mechanism: the environment is a TeX group, so \inproblemgrouptrue and the
% \leftskip indent below are both undone automatically at \end -- the flag falls
% back to false for whatever follows, and the margin is restored. The stem prints
% BEFORE the indent is set, so only the parts indent under it. The trailing \par
% flushes the last part while the indent is still in force.
\newenvironment{problemgroup}[1]{%
  \par\refstepcounter{problem}%
  \noindent\textbf{Problem \theproblem.}\quad\ignorespaces#1\par
  \addtolength{\leftskip}{2em}% indent the parts under the stem (tunable)
  \inproblemgrouptrue
}{%
  \par
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SOLUTION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% ForestGreen is a dvipsnames colour. Green reads as "answer" and stays clear of
% the OliveGreen course identity used for headings. Named once here so it can be
% retuned in one place.
\colorlet{SolutionColor}{ForestGreen}

% \NewEnviron captures the whole body as \BODY. When solutions are OFF we simply
% never emit \BODY -- the clean way to drop an environment's contents, and the
% same pattern IfThenBoxes.sty already uses for its solution-only boxes. A plain
% \newenvironment with \ifsolutions...\fi wrapped around the delimiters is
% fragile (the body is still scanned, and the \fi lands in the wrong group); this
% is not.
\NewEnviron{solution}{%
  \ifsolutions
    \par\smallskip
    \noindent{\bfseries\color{SolutionColor}Solution.}\quad\ignorespaces
    \BODY
    \par
  \fi
}
