\ProvidesPackage{Exercises}[2026/07/16 problem/solution environments + the solutions toggle]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% WHAT THIS IS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% The roll-your-own exercise system -- the homegrown answer to NOTE.md item 4,
% built instead of resurrecting xsim. It provides:
%
%   \begin{problem} ... \end{problem}     numbered, cross-referenceable
%   \begin{problemgroup}{STEM} ...         "Problem N." + stem; parts render (a),(b)
%   \begin{solution}[notitle] ...          printed only in the solutions build; a
%                                          colour box, [notitle] drops its corner tab
%   \begin{hint}[notitle] ...              printed only in the hints build; likewise
%   \begin{choices}[stacked|onepar|grid]   lettered MC options in that layout;
%     \choice{}  \choice[correct]{}        key boxed only in the solutions build
%     \graphchoice[correct]{FILE}          a graph option (label beside, centred)
%   \begin{matching} \leftitem[X]{} \rightcolumn \rightitem{}   two-column matching;
%     \leftgraph[X]{FILE} \rightgraph{FILE}     match shown inline in solutions
%   \importproblem[points=5, ...]{DIR}{FILE}  \import a problem; keyval options:
%                                             points= / nocount / hint / nohint
%                                             ([5] alone is shorthand for points=5)
%   \printtotalpoints                      the summed points of the assessment
%
% plus the independent \ifsolutions / \ifhints toggles that drive those two
% environments. Deliberately small: counters, a few environments, conditionals,
% one import wrapper -- all LaTeX primitives, none of xsim's expensive machinery.
% See NOTE.md item 4 for
% why that boundary is safe.
%
% SELF-CONTAINED ON PURPOSE. This is the ESSENTIAL package -- problem sets with
% optionally-printed solutions, the thing the course cannot be taught without.
% It does NOT depend on ProblemMeta.sty (the tagging, which is nice-to-have): if
% ProblemMeta broke or were removed, everything here still works. The class loads
% the two separately. As a final safety, the \AtBeginDocument stub below lets a
% problem file that still contains a \ProblemMeta{...} block compile even when
% ProblemMeta is absent -- the block is silently swallowed.
%
% VOCABULARY NOTE: the package is "Exercises" (NOTE.md's name for the system),
% but the author-facing environment is \begin{problem} -- the word the content
% already uses and the one Patrick is accustomed to. The mismatch is intentional.

\RequirePackage{environ}       % \NewEnviron: capture a body to conditionally emit
\RequirePackage{etoolbox}      % \ifdefempty, \ifdefstring
\RequirePackage{import}        % \import, wrapped by \importproblem
\RequirePackage{totcount}      % \newtotcounter/\total: two-pass sum for \printtotalpoints
\RequirePackage{keyval}        % \importproblem's [key=value] options
\RequirePackage{xstring}       % \IfInteger: lone-number back-compat for \importproblem
\RequirePackage{graphicx}      % \includegraphics, wrapped by \graphchoice (MC graphs)

% Own the colour dependency rather than borrowing ProblemMeta's -- this package
% must stand alone. dvipsnames for the named colour below; consistent with the
% option ProblemMeta and the classes pass, so no clash.
\PassOptionsToPackage{dvipsnames}{xcolor}
\RequirePackage{xcolor}

% The solution/hint bodies are set in tcolorboxes (see the SOLUTION section).
% Loaded here so this package still compiles standalone; [most] matches the
% option CourseBoxes passes, so loading both in one document does not clash.
\RequirePackage[most]{tcolorbox}

% If ProblemMeta is not loaded, make \ProblemMeta a no-op that swallows its
% argument, so problem files carrying a metadata block still compile. Deferred to
% \AtBeginDocument so it is order-independent: if ProblemMeta IS loaded (before or
% after this package), its real definition already exists and \providecommand
% does nothing; problem files are only read in the body, so the stub is in place
% in time either way.
\AtBeginDocument{\providecommand{\ProblemMeta}[1]{}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SOLUTIONS / HINTS TOGGLES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Both off by default (the plain student build). build-pdfs injects
% \def\ShowSolutions{} / \def\ShowHints{} on the command line for the -SOLUTIONS
% and -HINTS twins (see its `%! views: solutions, hints').
%
% The two are INDEPENDENT: a hint is student-facing help, a solution is the
% answer key -- different audiences, so a hints build is not a solutions build.
% List both views to get both (separate) PDFs; nothing here couples them.
%
% This lived in Test.cls as scaffolding. Moved here so it is SHARED: a problem
% file that carries its own \begin{solution} (or \begin{hint}) can now be
% \import-ed into a LECTURE (LectureNotes) as well as a test, which it could not
% when only Test.cls knew the machinery. That was NOTE.md item 4's open gap.
\newif\ifsolutions
\ifdefined\ShowSolutions \solutionstrue \fi
\newif\ifhints
\ifdefined\ShowHints \hintstrue \fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% POINTS (set at import time, NOT in the problem file)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% A problem has no intrinsic point value -- it is worth 5 on one assessment, 7 on
% another. So points are EXTRINSIC: specified where the problem is imported, not
% stored with it. (Contrast ProblemMeta's tags/difficulty, which ARE intrinsic
% and live in the file.) \importproblem stashes the value; the problem
% environment prints it and clears it, so it attaches to exactly one problem and
% never leaks to the next.
\newcommand{\CurrentProblemPoints}{}

% Whether the current problem's points count toward the total. "1" = counted
% (the default); "0" = shown but off the books. Set by the `nocount' key of
% \importproblem, read (and reset) in the problem environment alongside points.
% Serves two cases with one mechanism: BONUS questions (extra, so out of the
% denominator) and CHOOSE-1-OF-N pairs (mark all but one of the alternatives
% off-the-books, so a 10-or-10 pair contributes 10, not 20). It deliberately does
% NOT alter the printed marker -- "choose one" pairs must still read "(10 points)"
% on both, and which case it is (bonus vs. choose) is carried by exam prose.
\newcommand{\CurrentProblemCounts}{1}

% Per-problem override of the hints toggle, set by \importproblem's hint/nohint
% keys and read by the hint environment. Three states: "inherit" (the default --
% follow the document's \ifhints), "on" (force this problem's hint to show even in
% a no-hints build -- e.g. a few worked examples on a test), "off" (suppress even
% in a hints build). The global \ifhints view stays the document default; this is
% the per-import override layered on top, so both frameworks coexist.
\newcommand{\CurrentProblemHint}{inherit}

% How the points render next to the heading. Stylable in one place; the eventual
% target is the quarry's margin \fbox, but an inline marker is enough for now.
% \ifnum picks "point" vs "points" -- which is also why points must be an INTEGER
% (see \importproblem): \ifnum and the \addtocounter into the total both need one.
\newcommand{\ProblemPointsFormat}[1]{%
  \quad\textnormal{\normalfont(#1\ \ifnum#1=1 point\else points\fi)}}

% The assessment total. \newtotcounter registers a normal counter that totcount
% writes to the .aux at end-of-document; \total reads back the PREVIOUS run's
% final value, so \printtotalpoints is correct even at the TOP of the page (the
% usual "worth N points" line). First compile shows "??" and warns "Rerun ...";
% the aux changes, so latexmk reruns on its own. The counter is fed in the
% problem environment below, not here, so it counts problems that actually print.
\newtotcounter{totalpoints}
\newcommand{\printtotalpoints}{\total{totalpoints}}

% \importproblem[OPTIONS]{DIR}{FILE} -- \import a problem with per-import settings.
% OPTIONS is a comma-separated key=value list (keyval family `eximport'):
%
%   points=5    the point value (integer; summed and pluralised)
%   nocount     show the points but keep them OUT of the total (bonus / choose-1-of-N)
%   hint        force this problem's hint to show, regardless of the global toggle
%   nohint      suppress this problem's hint, regardless of the global toggle
%
% As a shorthand, a LONE integer means points: \importproblem[5]{...}{...} is
% exactly \importproblem[points=5]{...}{...} (this is the back-compat form and the
% common case). To combine points with a flag, write it out: [points=5, hint].
% (A bare number mixed with flags -- [5, hint] -- is NOT valid; keyval would read
% "5" as an unknown key. Use points=5.) Bare \import still works and yields no
% marker (e.g. a lecture, ungraded). The trailing reset restores every default for
% whatever follows -- a safety net for a file that sets no problem to consume them.
%
% New per-import axes slot in here as one more key (a future notes-to-marker note,
% per-part points, ...), which is why the interface moved to keyval.
\define@key{eximport}{points}{\gdef\CurrentProblemPoints{#1}}
\define@key{eximport}{nocount}[true]{\gdef\CurrentProblemCounts{0}}
\define@key{eximport}{hint}[true]{\gdef\CurrentProblemHint{on}}
\define@key{eximport}{nohint}[true]{\gdef\CurrentProblemHint{off}}

\newcommand{\importproblem@reset}{%
  \gdef\CurrentProblemPoints{}%
  \gdef\CurrentProblemCounts{1}%
  \gdef\CurrentProblemHint{inherit}%
}
\NewDocumentCommand{\importproblem}{O{} m m}{%
  \importproblem@reset
  \IfInteger{#1}{\gdef\CurrentProblemPoints{#1}}{\setkeys{eximport}{#1}}%
  \import{#2}{#3}%
  \importproblem@reset
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% A run-in bold heading "Problem N." then the body, matching the content's
% existing \textbf{Problem.} style but numbered, with the import-time points (if
% any) after it. \refstepcounter (not \stepcounter) so \label inside a problem
% points at the problem: \ref gives its number.
%
% The counter is flat and document-wide: each import of a problem file steps it,
% so a set of five imported problems numbers 1..5. To restart numbering per
% section, a document can \counterwithin{problem}{section}; to reset equation
% numbers per problem, \counterwithin{equation}{problem} -- neither is imposed
% here (they surprise as often as they help).
%
% The end code clears the points globally (\gdef): \import does not group its
% contents, but clearing globally is robust regardless and enforces consume-once.
\newcounter{problem}

% Grouped subquestions (see the PROBLEM GROUPS section). Inside a \problemgroup
% each imported problem renders as a lettered PART -- "(a)", "(b)" -- instead of
% "Problem N.". The flag below, set locally true by the group, is what the problem
% environment branches on; the same atomic file renders either way, so nothing in
% the library changes. The counter resets whenever `problem' steps (so each group,
% and each top-level problem, starts its letters at (a)); \p@subproblem makes a
% \ref to a part read "N(a)".
\newif\ifinproblemgroup
\newcounter{subproblem}[problem]
% \thesubproblem carries the parent number ("4(a)") so a \ref to a part reads
% "4(a)" -- the same nesting trick as \theequation under a section. The prefix
% must live INSIDE \thesubproblem, not in \p@subproblem: routed through \p@ the
% \number scan inside \arabic{problem} swallows the following token and the
% letter is lost. The heading prints just "(a)" via \alph directly (below), so the
% two representations differ on purpose -- short label on the page, full ref.
\renewcommand{\thesubproblem}{\theproblem(\alph{subproblem})}

% ---- Heading: class-overridable PRESENTATION -------------------------------
% A problem file is context-neutral -- \begin{problem} names no label of its own,
% because the SAME file is a numbered "Q" on a test and an "Example" in a lecture.
% The consuming class decides the look through two hooks, the same idiom as
% Titling's \TitleColor and Hyperlinks' \LinkColor:
%
%   \ProblemLabelWord     the noun -- "Problem" (default), "Q", "Example".
%   \ProblemNumberText    the FORMATTED number, "Problem N" / "Q N" / "Q N" (tight).
%                         One macro so the standalone heading and the group stem
%                         can never disagree; a class overrides it if the separator
%                         differs (Test wants "QN", no space).
%   \ProblemHeadingFormat typesets a TOP-LEVEL problem's whole heading. It runs
%                         AFTER the counter is stepped and (for a counted problem)
%                         the points are already in the total, so it is pure
%                         presentation -- read \ProblemNumberText / \CurrentProblemPoints
%                         and place them inline or in the margin, with no risk to
%                         the count. Default: run-in "Problem N." + inline points.
%   \ProblemGroupHeadingFormat{STEM}  the same, for a \problemgroup's numbered stem.
%
%   Test.cls overrides these to "Q N" over a points \fbox hung in the left margin;
%   LectureNotes.cls (later) to a run-in "Example.".
\newcommand{\ProblemLabelWord}{Problem}
\newcommand{\ProblemNumberText}{\ProblemLabelWord\ \theproblem}
\newcommand{\ProblemHeadingFormat}{%
  \noindent\textbf{\ProblemNumberText.}%
  \ifdefempty{\CurrentProblemPoints}{}{\ProblemPointsFormat{\CurrentProblemPoints}}%
  \quad
}
\newcommand{\ProblemGroupHeadingFormat}[1]{%
  \noindent\textbf{\ProblemNumberText.}\quad\ignorespaces#1\par
}

% The environment separates BOOKKEEPING (counter + running total -- never
% overridable, so a restyled heading can never disturb the point count) from
% PRESENTATION (the heading). A part inside a \problemgroup always renders as a
% lettered "(a)" run-in -- the group, not the class, owns that layout -- while a
% top-level problem goes through \ProblemHeadingFormat.
\newenvironment{problem}{%
  \par
  % --- Bookkeeping.
  \ifinproblemgroup\refstepcounter{subproblem}\else\refstepcounter{problem}\fi
  % \refstepcounter sets \@currentlabel LOCALLY, but this environment is a group
  % and the problem body arrives via \import -- so a \label written next to the
  % \importproblem (outside the group) would otherwise capture the *enclosing*
  % label, not this problem's. Globalise it so \label works from the assembly
  % file. hyperref already makes its anchor (\@currentHref) global, so this keeps
  % the ref text and the hyperlink target in sync.
  \global\let\@currentlabel\@currentlabel
  \ifdefempty{\CurrentProblemPoints}{}{%
    \ifdefstring{\CurrentProblemCounts}{1}{\addtocounter{totalpoints}{\CurrentProblemPoints}}{}%
  }%
  % --- Presentation.
  \ifinproblemgroup
    \noindent\textbf{(\alph{subproblem})}%
    \ifdefempty{\CurrentProblemPoints}{}{\ProblemPointsFormat{\CurrentProblemPoints}}%
    \quad
  \else
    \ProblemHeadingFormat
  \fi
  \ignorespaces
}{\par\gdef\CurrentProblemPoints{}\gdef\CurrentProblemCounts{1}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM GROUPS (subquestions)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \begin{problemgroup}{STEM} ... \end{problemgroup} -- a numbered "Problem N."
% carrying a shared instruction (STEM), under which each imported problem prints
% as a lettered part (a), (b), .... This is the ASSEMBLY-TIME wrapper: the parts
% stay atomic one-problem files in the bank and are pulled in with \importproblem
% exactly as anywhere else; the group only changes how they render. Use it for
% independent items sharing an instruction ("Evaluate the following integrals:").
% Genuinely dependent parts ("Let f(x)=...; (a)... (b)...") are ONE problem and
% belong in one file -- not this.
%
% Points are per-part (each \importproblem[..] inside carries its own), so the
% group takes no point value; the grand total sums the parts as usual, and a part
% may be starred (\importproblem*) to sit off the books.
%
% Mechanism: the environment is a TeX group, so \inproblemgrouptrue and the
% \leftskip indent below are both undone automatically at \end -- the flag falls
% back to false for whatever follows, and the margin is restored. The stem prints
% BEFORE the indent is set, so only the parts indent under it. The trailing \par
% flushes the last part while the indent is still in force.
\newenvironment{problemgroup}[1]{%
  \par\refstepcounter{problem}%
  \ProblemGroupHeadingFormat{#1}%
  \addtolength{\leftskip}{2em}% indent the parts under the stem (tunable)
  \inproblemgrouptrue
}{%
  \par
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SOLUTION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% ForestGreen is a dvipsnames colour. Green reads as "answer" and stays clear of
% the OliveGreen course identity used for headings. Named once here so it can be
% retuned in one place.
\colorlet{SolutionColor}{ForestGreen}

% The look of the solution/hint boxes, factored so both retune in a single place
% (the same one-place-to-restyle idiom as CourseBoxes' cb/... styles). Two pieces:
%
%   ex/answerbox={COLOUR}       the box itself -- light fill, thin frame, sharp
%                               corners, leftskip-aware width. NO tab.
%   ex/answertab={COLOUR}{WORD} the small white-on-colour tab hung over the top-
%                               left border (the SolutionBox look from the old
%                               custom-cls-sty).
%
% Composed into four styles: ex/solution / ex/hint (box + tab) and their
% ex/...plain twins (box only, for \begin{solution}[notitle]). Splitting the tab
% out is what makes the tab suppressible per box -- the plain twin simply omits it
% (and trims the top padding, since there is no tab to clear). ex/hint and its
% plain twin live in the HINT section, once HintColor exists.
%
% parbox=false so display math and multiple paragraphs in the body set normally;
% breakable so a long body can cross a page. The tab fill is a strong tint (!80)
% so the white tab text keeps its contrast.
\tcbset{
  ex/answerbox/.style={
    enhanced, breakable, parbox=false,
    colback=#1!5, colframe=#1!60,
    sharp corners, boxrule=0.2mm,
    left=6pt, right=6pt, top=10pt, bottom=6pt,
    % Shrink the box by the active \leftskip so it never overhangs the right
    % margin. A tcolorbox defaults to width=\linewidth, but \leftskip (e.g. the
    % 2em problemgroup part-indent) adds glue to the line WITHOUT reducing
    % \linewidth -- so an unshrunk box runs \leftskip past the margin (the "24pt
    % too wide" overfull). At top level \leftskip is 0pt, so this is just \linewidth.
    width=\dimexpr\linewidth-\leftskip\relax,
  },
  ex/answertab/.style 2 args={
    coltitle=white, colbacktitle=#1!80,
    title={\sffamily\footnotesize #2},
    % xshift aligns the tab's LABEL TEXT with the body text's left margin (the
    % tab's left edge overhangs a touch into the border), so the label reads as a
    % heading over its paragraph. Tuned to the left= paddings here; retune if those
    % change. (Use ~16pt instead to make the tab's left EDGE flush with the body.)
    attach boxed title to top left={xshift=8.5pt, yshift=-\tcboxedtitleheight/2},
    boxed title style={
      size=small, boxrule=0pt, sharp corners,
      colback=#1!70,
      top=0.5pt, bottom=0.5pt, left=1.5pt, right=1.5pt,
    },
  },
  ex/solution/.style     ={ex/answerbox=SolutionColor, ex/answertab={SolutionColor}{solution}},
  ex/solutionplain/.style={ex/answerbox=SolutionColor, top=6pt},
}

% Zero-height overlay routing. Workspace.sty (loaded by Test/LectureNotes) defines
% \WSZeroHeight, which in the default OVERLAY mode emits a box at zero height so it
% paints down into the reserved \workspace instead of shifting the layout; under
% \solidboxes it emits normally. Both the solution and hint environments route their
% box through it. Exercises stays SELF-CONTAINED: if Workspace is absent (e.g. under
% CourseDocument), this \AtBeginDocument fallback makes \WSZeroHeight a pass-through,
% so the boxes just render at normal height. \providecommand at begin-document, so
% the real definition wins whenever Workspace is loaded (before or after us).
\AtBeginDocument{\providecommand{\WSZeroHeight}[1]{#1}}

% Per-box options, keyval family `exbox' -- the same idiom as \importproblem's
% `eximport'. Shared by \begin{solution} and \begin{hint} (both take an optional
% [key,...] argument). One key for now; future per-box axes slot in as one more.
%
%   notitle   drop the corner tab, leaving just the coloured box
%
% \ifex@notitle is reset false before each box, so the option never leaks to the
% next; \setkeys errors loudly on an unknown key (a typo), as eximport does.
\newif\ifex@notitle
\define@key{exbox}{notitle}[true]{\ex@notitletrue}

% \NewEnviron captures the whole body as \BODY. When solutions are OFF we simply
% never emit \BODY -- the clean way to drop an environment's contents, and the
% same pattern IfThenBoxes.sty already uses for its solution-only boxes. A plain
% \newenvironment with \ifsolutions...\fi wrapped around the delimiters is
% fragile (the body is still scanned, and the \fi lands in the wrong group); this
% is not. When solutions are ON, the body is set inside the ex/solution box --
% or ex/solutionplain (no tab) for \begin{solution}[notitle].
\NewEnviron{solution}[1][]{%
  \ifsolutions
    \ex@notitlefalse
    \setkeys{exbox}{#1}%
    \par
    \ifex@notitle
      \WSZeroHeight{\begin{tcolorbox}[ex/solutionplain]\BODY\end{tcolorbox}}%
    \else
      \WSZeroHeight{\begin{tcolorbox}[ex/solution]\BODY\end{tcolorbox}}%
    \fi
  \fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HINT
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Same shape as SOLUTION, gated by the independent \ifhints toggle. Inline where
% written (NOT collected at the end, as xsim's hint model does) -- which is the
% whole reason we wanted our own. BurntOrange reads as a warm "tip" aside, clearly
% apart from the green of solutions, and is not a link colour (so it never reads
% as a hyperlink in a Hyperlinks-loading lecture). Retune in one place.
\colorlet{HintColor}{BurntOrange}

% Same box as the solution, in the hint colour + word -- composed from the shared
% ex/answerbox + ex/answertab pieces in the SOLUTION section, so the two never
% drift apart. ex/hintplain is the no-tab twin for \begin{hint}[notitle].
\tcbset{
  ex/hint/.style     ={ex/answerbox=HintColor, ex/answertab={HintColor}{hint}},
  ex/hintplain/.style={ex/answerbox=HintColor, top=6pt},
}

% Three-state visibility (see \CurrentProblemHint): the per-import hint/nohint keys
% force this hint on/off; "inherit" (the default, and every non-\importproblem
% context) follows the document \ifhints toggle. \showhint collapses the three
% states to one boolean the emit-or-drop below reads.
\newif\ifshowhint
\NewEnviron{hint}[1][]{%
  \showhintfalse
  \ifdefstring{\CurrentProblemHint}{on}{\showhinttrue}{%
    \ifdefstring{\CurrentProblemHint}{off}{}{\ifhints\showhinttrue\fi}%
  }%
  \ifshowhint
    \ex@notitlefalse
    \setkeys{exbox}{#1}%
    \par
    \ifex@notitle
      \WSZeroHeight{\begin{tcolorbox}[ex/hintplain]\BODY\end{tcolorbox}}%
    \else
      \WSZeroHeight{\begin{tcolorbox}[ex/hint]\BODY\end{tcolorbox}}%
    \fi
  \fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% MULTIPLE CHOICE (choices list)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% An MC question is NOT a separate problem type -- it is a normal \begin{problem}
% (numbered, points via \importproblem, filterable via \ProblemMeta tags) whose
% body carries a choices list. ONE environment, three layouts via an optional arg:
%
%   \begin{choices}          one option per line   (default; long options)
%   \begin{choices}[onepar]  options inline         (short: Even/Odd/Neither/Both)
%   \begin{choices}[grid]    a \ChoicesGridCols-wide grid, row-major (default 2)
%
%   \begin{problem}
%     What is the domain of ...?
%     \begin{choices}
%       \choice{$\{x : x\ge -1\}$}
%       \choice[correct]{$\{x : x\ge -1,\ x\ne 7\}$}
%       ...
%     \end{choices}
%   \end{problem}
%
% Options are lettered (A), (B), .... A \choice is marked the key by the optional
% argument -- \choice[correct]{...} -- so swapping which option is correct is an
% in-place edit, no command rename. (Any value in the bracket means "key"; the
% word `correct' is just the readable spelling.) The key is boxed ONLY in a
% solutions build (gated by \ifsolutions, the same toggle as \begin{solution}), so
% the answer never leaks; several may be marked (select-all-that-apply).
%
% The grid is built from \parbox cells laid with \hfill/\par, NOT a tabular: a
% macro (\choice) that emits alignment tokens & / \\ from inside conditionals
% breaks both tabular and tabularray (they scan for those tokens); \hfill and \par
% are safe in conditionals, need no table package, and still wrap long options.
\newcounter{choice}
\newcommand{\ChoicesGridCols}{2}   % columns in [grid]; \renewcommand to change
\newcount\choice@col               % column position within the current grid row
\newlength{\choice@gridwidth}
\newcommand{\choice@layout}{stacked}

% How the key is boxed in a solutions build: a tight green frame + light fill
% (matching the quarry's \Answer{} box), via \fcolorbox so no tcolorbox is needed.
% SolutionColor is defined in the SOLUTION section above. NB \fcolorbox is an
% \mbox, so a *very* long correct option will not line-break inside the box --
% fine for typical MC options, which are short; restyle here if that ever bites.
\newcommand{\CorrectChoiceFormat}[1]{%
  {\setlength{\fboxrule}{0.2mm}\fcolorbox{SolutionColor}{SolutionColor!8}{#1}}%
}

% Shared: render option text, boxed iff this \choice is the key AND solutions on.
% \choice resolves correctness (from the optional arg) into \choice@iscorrect,
% then hands the text to the current layout's emitter.
\newcommand{\choice@iscorrect}{0}
\newcommand{\choice@content}[1]{%
  \ifdefstring{\choice@iscorrect}{1}%
    {\ifsolutions\CorrectChoiceFormat{#1}\else#1\fi}{#1}%
}
\NewDocumentCommand{\choice}{o m}{%
  \stepcounter{choice}%
  \IfNoValueTF{#1}{\def\choice@iscorrect{0}}{\def\choice@iscorrect{1}}%
  \csname choice@@\choice@layout\endcsname{#2}%
}

% Per-layout emitters (each gets the option text as #1).
\newcommand{\choice@@stacked}[1]{\item[(\Alph{choice})]\choice@content{#1}}
\newcommand{\choice@@onepar}[1]{%
  \choice@sep(\Alph{choice})~\choice@content{#1}\let\choice@sep\qquad}
% Grid: separator BEFORE each cell (safe: \hfill / \par\nobreak, never & / \\).
\newcommand{\choice@@grid}[1]{%
  \ifnum\choice@col=0 \else
    \ifnum\choice@col<\numexpr\ChoicesGridCols\relax
      \hfill
    \else
      \global\choice@col=0 \par\nobreak
    \fi
  \fi
  \ifnum\choice@col=0 \noindent\fi
  \parbox[t]{\choice@gridwidth}{(\Alph{choice})~\choice@content{#1}}%
  \global\advance\choice@col1
}

% Per-layout environment begin/end, dispatched by the optional argument.
\newcommand{\choices@begin@stacked}{%
  \list{}{%
    \setlength{\leftmargin}{2.5em}\setlength{\labelwidth}{2em}%
    \setlength{\labelsep}{0.5em}\setlength{\itemsep}{0.2ex}%
    \setlength{\topsep}{0.4\baselineskip}}%
}
\newcommand{\choices@end@stacked}{\endlist}
\newcommand{\choices@begin@onepar}{\let\choice@sep\empty\noindent\ignorespaces}
\newcommand{\choices@end@onepar}{\par}
\newcommand{\choices@begin@grid}{%
  \global\choice@col=0
  \setlength{\choice@gridwidth}{\dimexpr\linewidth/\ChoicesGridCols - 1.5em\relax}%
  \par}
\newcommand{\choices@end@grid}{\par}

\NewDocumentEnvironment{choices}{O{stacked}}{%
  \par\setcounter{choice}{0}%
  \@ifundefined{choices@begin@#1}%
    {\PackageError{Exercises}{Unknown choices layout `#1'}%
       {Use one of: stacked, onepar, grid.}}%
    {\def\choice@layout{#1}\csname choices@begin@#1\endcsname}%
}{%
  \csname choices@end@\choice@layout\endcsname
}

% \graphchoice[correct]{FILE} -- a \choice whose content is a GRAPH, for a
% [grid] of graphs. It (1) sizes the image to the column minus room for the "(A)"
% label, so the label sits BESIDE the graph without overflowing, and (2) vertically
% aligns the graph against the label per \GraphChoiceValign: c=middle (default,
% the least ambiguous), t=label at the graph's top, b=label at its bottom. The
% alignment lives here, on the graph, NOT on the grid -- so a grid of plain text
% \choice options keeps its correct baseline alignment. Middle is just a raisebox:
% centre the image on the label's baseline. Restyle width/alignment in one place.
\newcommand{\GraphChoiceValign}{c}
\newcommand{\graphchoice@raise}[1]{%
  \ifdefstring{\GraphChoiceValign}{t}{\raisebox{-\height}{#1}}{%
    \ifdefstring{\GraphChoiceValign}{b}{#1}{\raisebox{-0.5\height}{#1}}}%
}
\newcommand{\graphchoice@box}[1]{%
  \graphchoice@raise{\includegraphics[width=\dimexpr\linewidth-2.4em\relax]{#1}}%
}
\NewDocumentCommand{\graphchoice}{o m}{%
  \IfNoValueTF{#1}%
    {\choice{\graphchoice@box{#2}}}%
    {\choice[#1]{\graphchoice@box{#2}}}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% MATCHING
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Like MC, a matching question is a normal \begin{problem} whose body is a
% \begin{matching}: a LEFT column of items numbered (1),(2),... and a RIGHT column
% lettered (A),(B),..., with a wide gap for students to draw connecting lines.
% \rightcolumn splits the two. Items may be text (\leftitem/\rightitem) or graphs
% (\leftgraph/\rightgraph, which reuse \graphchoice's sizing + centring):
%
%   \begin{problem}
%     Match each graph with the phrase that best describes it.
%     \begin{matching}
%       \leftgraph[C]{graph-1}    % this left item's match is right item C
%       \leftgraph[A]{graph-2}
%       \rightcolumn
%       \rightitem{Concave up}    % (A)
%       \rightitem{Concave down}  % (B)
%       ...
%     \end{matching}
%   \end{problem}
%
% The answer is intrinsic, like \choice[correct]: a left item names its match in
% the optional argument. In a SOLUTIONS build that match is shown inline next to
% the item ("(1) [graph] $\to$ C"), gated by \ifsolutions -- deliberately NO drawn
% arrows (they are only aesthetic and would force a TikZ dependency + a two-pass
% compile). Left/right counts may differ (distractors). Tunables: \MatchColWidth
% (each column; the remainder is the gap), \MatchItemSep, \MatchKeyFormat.
%
% Two columns are two side-by-side \minipage[t]s; \rightcolumn ends the left one
% and opens the right (raw \minipage/\endminipage so the split can straddle it).
\newcounter{matchleft}
\newcounter{matchright}
\newlength{\match@colwidth}
\newcommand{\MatchColWidth}{0.38\linewidth}
\newcommand{\MatchItemSep}{2ex}
\newcommand{\MatchKeyFormat}[1]{\;{\bfseries\color{SolutionColor}$\to$#1}}

% The match annotation rides on the NUMBER label -- "(1) -> C" -- not after the
% content, so it always fits even when the content is a column-filling graph
% (where trailing text would wrap below it).
\NewDocumentCommand{\leftitem}{o m}{%
  \par\stepcounter{matchleft}%
  \noindent(\arabic{matchleft})%
  \IfNoValueF{#1}{\ifsolutions\MatchKeyFormat{#1}\fi}%
  \quad #2%
  \par\vspace{\MatchItemSep}%
}
\NewDocumentCommand{\rightitem}{m}{%
  \par\stepcounter{matchright}%
  \noindent(\Alph{matchright})\quad #1%
  \par\vspace{\MatchItemSep}%
}
\NewDocumentCommand{\leftgraph}{o m}{%
  \IfNoValueTF{#1}%
    {\leftitem{\graphchoice@box{#2}}}%
    {\leftitem[#1]{\graphchoice@box{#2}}}%
}
\newcommand{\rightgraph}[1]{\rightitem{\graphchoice@box{#1}}}

\newcommand{\rightcolumn}{\endminipage\hfill\minipage[t]{\match@colwidth}}
\newenvironment{matching}{%
  \par\setcounter{matchleft}{0}\setcounter{matchright}{0}%
  \setlength{\match@colwidth}{\MatchColWidth}%
  \par\noindent\minipage[t]{\match@colwidth}%
}{%
  \endminipage\par
}
