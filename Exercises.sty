\ProvidesPackage{Exercises}[2026/07/16 problem/solution environments + the solutions toggle]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% WHAT THIS IS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% The roll-your-own exercise system, built instead of adopting xsim (the
% why-not is recorded in manual/ch-architecture.tex). It provides:
%
%   \begin{problem} ... \end{problem}     numbered, cross-referenceable
%   \begin{problemgroup}{STEM} ...         "Problem N." + stem; parts render (a),(b)
%   \begin{solution}[notitle] ...          printed only in the solutions build; a
%                                          colour box, [notitle] drops its corner tab
%   \begin{hint} ... \end{hint}            printed only in the hints build; a plain
%                                          "HINT:" run-in, italic body (no box)
%   \begin{choices}[stacked|onepar|grid]   lettered MC options in that layout;
%     \choice{}  \choice[correct]{}        key boxed only in the solutions build
%     \graphchoice[correct]{FILE}          a graph option (label beside, centred)
%   \begin{matching} \leftitem[X]{} \rightcolumn \rightitem{}   two-column matching;
%     \leftgraph[X]{FILE} \rightgraph{FILE}     match shown inline in solutions
%   \importproblem[points=5, ...]{DIR}{FILE}  \import a problem; keyval options:
%                                             points= / nocount / hint / nohint
%                                             ([5] alone is shorthand for points=5)
%   \importfact[number=, desc=]{DIR}{FILE} \import a bare fact; provenance only,
%                                             shown via the opt-in \ShowFactMeta
%   \printtotalpoints                      the summed points of the assessment
%
% plus the independent \ifsolutions / \ifhints toggles that drive those two
% environments. Deliberately small: counters, a few environments, conditionals,
% one import wrapper -- all LaTeX primitives, none of xsim's expensive machinery
% (manual/ch-architecture.tex records why that boundary is safe).
%
% SELF-CONTAINED ON PURPOSE. This is the ESSENTIAL package -- problem sets with
% optionally-printed solutions, the thing the course cannot be taught without.
% It does NOT depend on ProblemMeta.sty (the tagging, which is nice-to-have): if
% ProblemMeta broke or were removed, everything here still works. The class loads
% the two separately. As a final safety, the \AtBeginDocument stub below lets a
% problem file that still contains a \ProblemMeta{...} block compile even when
% ProblemMeta is absent -- the block is silently swallowed.
%
% VOCABULARY NOTE: the package is named "Exercises", but the author-facing
% environment is \begin{problem} -- the word course content already uses.
% The mismatch is intentional.

\RequirePackage{environ}       % \NewEnviron: capture a body to conditionally emit
\RequirePackage{etoolbox}      % \ifdefempty, \ifdefstring
\RequirePackage{import}        % \import, wrapped by \importproblem
\RequirePackage{totcount}      % \newtotcounter/\total: two-pass sum for \printtotalpoints
\RequirePackage{keyval}        % \importproblem's [key=value] options
\RequirePackage{xstring}       % \IfInteger: lone-number back-compat for \importproblem
\RequirePackage{graphicx}      % \includegraphics, wrapped by \graphchoice (MC graphs)

% Own the colour dependency rather than borrowing ProblemMeta's -- this package
% must stand alone. dvipsnames for the named colour below; consistent with the
% option ProblemMeta and the classes pass, so no clash.
\PassOptionsToPackage{dvipsnames}{xcolor}
\RequirePackage{xcolor}

% The solution/hint bodies are set in tcolorboxes (see the SOLUTION section).
% Loaded here so this package still compiles standalone; [most] matches the
% option CourseBoxes passes, so loading both in one document does not clash.
\RequirePackage[most]{tcolorbox}

% If ProblemMeta is not loaded, make \ProblemMeta a no-op that swallows its
% argument, so problem files carrying a metadata block still compile. Deferred to
% \AtBeginDocument so it is order-independent: if ProblemMeta IS loaded (before or
% after this package), its real definition already exists and \providecommand
% does nothing; problem files are only read in the body, so the stub is in place
% in time either way.
\AtBeginDocument{\providecommand{\ProblemMeta}[1]{}}
% Likewise for \FactMeta: a fact file carrying a metadata block compiles even
% when FactMeta.sty is absent (the block is silently swallowed). \importfact
% below is separate machinery -- this stub only guards the store-only block.
\AtBeginDocument{\providecommand{\FactMeta}[1]{}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SOLUTIONS / HINTS TOGGLES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Both off by default (the plain student build). build-pdfs injects
% \def\ShowSolutions{} / \def\ShowHints{} on the command line for the -SOLUTIONS
% and -HINTS twins (see its `%! views: solutions, hints').
%
% The two are INDEPENDENT: a hint is student-facing help, a solution is the
% answer key -- different audiences, so a hints build is not a solutions build.
% List both views to get both (separate) PDFs; nothing here couples them.
%
% This lived in Assessment.cls as scaffolding. Moved here so it is SHARED: a problem
% file that carries its own \begin{solution} (or \begin{hint}) can now be
% \import-ed into a LECTURE (LectureNotes) as well as a test, which it could not
% when only Assessment.cls knew the machinery.
\newif\ifsolutions
\ifdefined\ShowSolutions \solutionstrue \fi
\newif\ifhints
\ifdefined\ShowHints \hintstrue \fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% POINTS (set at import time, NOT in the problem file)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% A problem has no intrinsic point value -- it is worth 5 on one assessment, 7 on
% another. So points are EXTRINSIC: specified where the problem is imported, not
% stored with it. (Contrast ProblemMeta's tags/difficulty, which ARE intrinsic
% and live in the file.) \importproblem stashes the value; the problem
% environment prints it and clears it, so it attaches to exactly one problem and
% never leaks to the next.
\newcommand{\CurrentProblemPoints}{}

% Whether the current problem's points count toward the total. "1" = counted
% (the default); "0" = shown but off the books. Set by the `nocount' key of
% \importproblem, read (and reset) in the problem environment alongside points.
% `nocount' is the SILENT off-books primitive: it does NOT alter the printed marker
% -- a CHOOSE-1-OF-N pair must still read "(10 points)" on both, and which one is
% dropped is carried by exam prose (or by \problemchoice, which owns that accounting
% now). BONUS points are a SEPARATE mechanism -- the `*' suffix (points=2*), which is
% off-books AND labels the marker "bonus" (see \ifCurrentProblemBonus below). So the
% two are distinct: `nocount' = quiet, `*' = announced.
\newcommand{\CurrentProblemCounts}{1}

% Whether the current problem's points are BONUS -- set by a `*' suffix on the value
% (points=2*, or a per-part list entry points={2,3,1*}). A bonus item is kept out of
% the total (like nocount) AND its marker is rendered through \ProblemBonusPointsFormat
% (the "bonus" annotation) instead of \ProblemPointsFormat. Extrinsic: the `*' is
% detected at the import site, the content file is untouched. The scalar case sets
% this global (in \bonus@scalar, before the import); \ExPart sets it per part, locally.
\newif\ifCurrentProblemBonus

% Per-problem override of the hints toggle, set by \importproblem's hint/nohint
% keys and read by the hint environment. Three states: "inherit" (the default --
% follow the document's \ifhints), "on" (force this problem's hint to show even in
% a no-hints build -- e.g. a few worked examples on a test), "off" (suppress even
% in a hints build). The global \ifhints view stays the document default; this is
% the per-import override layered on top, so both frameworks coexist.
\newcommand{\CurrentProblemHint}{inherit}

% Whether the file just imported actually CONTAINS a hint environment -- set by
% \begin{hint} whether or not the hint displays, reset per import. Read after
% the \import to catch [hint] forced on a hint-less file: you explicitly asked
% for a hint to show in every build and nothing would appear, in build variants
% you may never proof -- so that silence earns a warning (see \importproblem).
\newif\ifEx@hintseen

% Literal display number for the current problem, set by \importproblem's
% `number' key. Empty (the default) means the CONTEXT decides: on a test the
% `problem' counter numbers it; in lecture notes it prints unnumbered. A
% non-empty value is a plain STRING -- typically a textbook's own number, e.g.
% "2.1.8" -- printed verbatim next to the label word and used as the \label
% target. It steps NO counter, so an imported textbook number never competes
% with a numbering scheme of your own. Only a class that shows it (LectureNotes)
% reads this; Assessment.cls ignores it (an exam owns its own numbering).
\newcommand{\CurrentProblemNumber}{}

% Free-text parenthetical shown after the heading, set by \importproblem's
% `desc' key -- e.g. "Example (similar to 2.1.8)". Empty (default) prints
% nothing. Like `number', pure presentation: the notes heading appends it in
% parentheses; Assessment.cls ignores it (an exam question is not annotated).
\newcommand{\CurrentProblemDesc}{}

% Whether the current import prints at all. \importproblem's `noprint' flag
% (equivalently print=false) clears this, and \importproblem then SKIPS the
% \import entirely -- the file is not read, so no counter steps, no points are
% tallied, and no \label target is made. Default true. Skip-entirely is
% deliberate (not typeset-then-hide): hiding output while still stepping the
% counter would leave numbering gaps and silently inflate the points total.
\newif\ifCurrentProblemPrint
\CurrentProblemPrinttrue

% Check-in mode, set by \importproblem's `checkin' key (and the \importcheckin
% shorthand). When active, an imported multiple-choice problem is wrapped in a
% neutral "Check In" box (a run-in "CHECK IN:" header, non-breakable), its own
% heading is suppressed (the box header is the label), and the choice labels
% render as the colored A/B/C flashcard boxes instead of "(A) (B) (C)" -- in
% whatever layout the file chose (stacked/onepar/grid). A
% notes-only flavour in practice; a bare (non-MC) problem imported this way just
% gets the box. The colored-label machinery + the box live in the MULTIPLE
% CHOICE section below (tcolorbox/xcolor are loaded); the flag lives here because
% \importproblem@reset must clear it.
\newif\ifcheckinmode
\checkinmodefalse

% How the points render next to the heading. Stylable in one place; the eventual
% target is the quarry's margin \fbox, but an inline marker is enough for now.
% \ifnum picks "point" vs "points" -- which is also why points must be an INTEGER
% (see \importproblem): \ifnum and the \addtocounter into the total both need one.
\newcommand{\ProblemPointsFormat}[1]{%
  \quad\textnormal{\normalfont(#1\ \ifnum#1=1 point\else points\fi)}}

% How a BONUS marker (points=2*) renders. Class-overridable, the twin of
% \ProblemPointsFormat; default is the inline mark with a ", bonus" note. Assessment.cls
% overrides it with a stacked right-margin block ("(N pts)" + rule + "bonus"). The
% value is still shown (a bonus IS worth N if earned); it is only kept OUT of the
% total, and announced.
\newcommand{\ProblemBonusPointsFormat}[1]{%
  \quad\textnormal{\normalfont(#1\ \ifnum#1=1 point\else points\fi, bonus)}}

% The single DISPATCH every heading calls to print a value's marker: bonus items go
% through \ProblemBonusPointsFormat, ordinary ones through \ProblemPointsFormat. So a
% class overrides the two FORMATS and never has to branch on bonus itself; and the
% scalar heading, group-part, and \qpart paths all agree by routing through here.
\newcommand{\ProblemPointsMark}[1]{%
  \ifCurrentProblemBonus\ProblemBonusPointsFormat{#1}\else\ProblemPointsFormat{#1}\fi}

% ---- Case-2 multipart points (see PROBLEM PARTS) ---------------------------
% A case-2 problem -- ONE file, genuinely dependent parts "(a) (b) (c)" -- takes
% its point split at the IMPORT site, keeping points extrinsic like everywhere
% else (the file's \qpart's stay pure structure, no weights baked in). Two forms,
% both handled by the `points'/`pointseach' keys below:
%
%   points={1,1,2}   POSITIONAL: the k-th value is the k-th part's points. The
%                    part count must match the list length or it errors (too few
%                    caught at \end{qparts}, too many the moment a part outruns the
%                    list); a list but no `qparts' at all is caught in \end{problem}.
%   pointseach=2     BROADCAST: every part is worth 2, whatever the count. (A bare
%                    `points=2' can NOT mean this -- it is indistinguishable from a
%                    single 2-point problem until the parts appear in the body,
%                    which is too late for the heading; hence a separate key.)
%
% Both leave \CurrentProblemPoints EMPTY, so the STEM heading shows no mark and
% adds nothing to the total on its own -- the parts carry the points, summing into
% `totalpoints' as each renders. The list is stored element-by-element as
% \ExPartPts@k with its length in \CurrentPartCount; \ifPartsListMode /
% \ifPartsEachMode select the path; \ifPartsSeen (reset per problem) lets
% \end{problem} catch a points spec that no `qparts' environment ever consumed.
\newif\ifPartsListMode
\newif\ifPartsEachMode
\newif\ifPartsSeen
\newif\ifExFirstPart  % first \qpart runs into the stem line; the rest each break
\newcommand{\CurrentPartEach}{}
\newcommand{\CurrentPartCount}{0}
\newcounter{exparttmp}  % scratch: counts list elements while parsing

% ---- Case-2 per-part WORKSPACES (see PROBLEM PARTS) -------------------------
% workspaces={1,2,3} injects a \workspace[k] after the k-th \qpart, set at the
% IMPORT site so the content file carries no \workspace directive -- workspace
% sizing is an ASSESSMENT concern (a lecture wants none, a test wants sized
% blanks), extrinsic like points. POSITIONAL: one entry per \qpart, an entry of
% 0 or empty meaning "no room for this part" (some parts -- "state the rule" --
% need none); keyword sizes (halfpage / fullpage) are fine as entries too, since
% commas inside the brace group cannot occur in them. Stored element-by-element
% as \ExWs@k with the length in \CurrentWSCount; \ifWorkspacesMode selects the
% path, and (like the points list) the count must equal the number of \qpart s.
\newif\ifWorkspacesMode
\newcommand{\CurrentWSCount}{0}

% Split a comma list "a,b,c" into \csname<PREFIX>k\endcsname (k=1..N) and record
% N in the count macro. Spaces are zapped first so "1, 1, 2" is accepted too.
% \@for is the kernel comma-list walker (it copes with empty elements, e.g. the
% skip entry in workspaces={1,,3}); each element is stored GLOBALLY because the
% list is parsed here (at the \importproblem call) but consumed later, inside the
% problem body's `qparts' environment. Shared by the two positional lists below.
%   #1  control-sequence-name prefix for the per-element stores (e.g. "ExPartPts@")
%   #2  a macro \xdef'd with the element count (e.g. \CurrentPartCount)
%   #3  the raw comma list
\newcommand{\Exercises@parselist}[3]{%
  \setcounter{exparttmp}{0}%
  \edef\Ex@list{\zap@space#3 \@empty}%
  \@for\Ex@elt:=\Ex@list\do{%
    \stepcounter{exparttmp}%
    \global\csxdef{#1\arabic{exparttmp}}{\Ex@elt}%
  }%
  \xdef#2{\arabic{exparttmp}}%
}
% The two callers: a positional points list (\ExPartPts@k, length \CurrentPartCount)
% and a positional workspaces list (\ExWs@k, length \CurrentWSCount). Each flips
% its mode flag and delegates the parse.
\newcommand{\ExercisesParsePointsList}[1]{%
  \global\PartsListModetrue
  \Exercises@parselist{ExPartPts@}{\CurrentPartCount}{#1}%
}
\newcommand{\ExercisesParseWorkspaceList}[1]{%
  \global\WorkspacesModetrue
  \Exercises@parselist{ExWs@}{\CurrentWSCount}{#1}%
}

% The assessment total. \newtotcounter registers a normal counter that totcount
% writes to the .aux at end-of-document; \total reads back the PREVIOUS run's
% final value, so \printtotalpoints is correct even at the TOP of the page (the
% usual "worth N points" line). First compile shows "??" and warns "Rerun ...";
% the aux changes, so latexmk reruns on its own. The counter is fed in the
% problem environment below, not here, so it counts problems that actually print.
\newtotcounter{totalpoints}
\newcommand{\printtotalpoints}{\total{totalpoints}}

% \importproblem[OPTIONS]{DIR}{FILE} -- \import a problem with per-import settings.
% OPTIONS is a comma-separated key=value list (keyval family `eximport'):
%
%   points=5      the point value (integer; summed and pluralised)
%   points=2*     BONUS: shown and labelled "bonus", but kept OUT of the total (the
%                 `*' suffix; see \ifCurrentProblemBonus). Works per-part too, below.
%   points={1,1,2} case-2 POSITIONAL split: the k-th value is the k-th \qpart's
%                 points (parts live in a `qparts' env in the file). Count must
%                 match the number of parts. A `*' on an entry (points={2,3,1*})
%                 makes THAT part bonus. See the POINTS / PROBLEM PARTS blocks.
%   pointseach=2  case-2 BROADCAST: every \qpart is worth 2, whatever the count
%                 (pointseach=2* makes every part bonus).
%   workspaces={1,2,3}  case-2 per-part handwriting room: a \workspace[k] after the
%                 k-th \qpart (0/empty = none). Count must match the \qpart count.
%   nocount       show the points but keep them OUT of the total, marker UNCHANGED
%                 (choose-1-of-N: no "bonus" label -- that is what `*' is for)
%   hint          force this problem's hint to show, regardless of the global toggle
%   nohint        suppress this problem's hint, regardless of the global toggle
%   number=2.1.8  literal display number (e.g. a textbook's); steps NO counter,
%                 used as the \label text. Empty = the context numbers it (or not).
%   desc={...}    parenthetical shown after the heading in a notes context.
%   noprint       skip this import entirely (equivalently print=false): no output,
%                 no counter step, no points, no \label -- the file is not read.
%   checkin       render as a "check-in": wrap in a neutral box with a run-in
%                 "CHECK IN:" header, suppress the problem's own heading, and color
%                 the A/B/C labels (see \importcheckin and MULTIPLE CHOICE).
%
% As a shorthand, a LONE integer means points: \importproblem[5]{...}{...} is
% exactly \importproblem[points=5]{...}{...} (this is the back-compat form and the
% common case); a lone [2*] is likewise points=2* (a bonus). To combine points with
% a flag, write it out: [points=5, hint].
% (A bare number mixed with flags -- [5, hint] -- is NOT valid; keyval would read
% "5" as an unknown key. Use points=5.) Bare \import still works and yields no
% marker (e.g. a lecture, ungraded). The trailing reset restores every default for
% whatever follows -- a safety net for a file that sets no problem to consume them.
%
% Nonsensical-but-compilable combinations WARN (never error): checkin with a
% points spec, points={...} together with pointseach, [hint] on a file carrying
% no hint environment, and (in the env itself) a problemchoice member with its
% own points=. See the "Consistency warnings" block above \importproblem.
%
% New per-import axes slot in here as one more key (a future notes-to-marker note,
% per-part points, ...), which is why the interface moved to keyval.
% A COMMA in the value marks a case-2 positional list (points={1,1,2}); anything
% else is an ordinary single-problem scalar. The list branch parses into the
% per-part store and deliberately leaves \CurrentProblemPoints empty (the parts,
% not the stem, carry the marks). See the case-2 block in the POINTS section.
\define@key{eximport}{points}{%
  \IfSubStr{#1}{,}%
    {\ExercisesParsePointsList{#1}}%
    {\bonus@scalar{#1}}%
}
% Store a scalar points value, honouring a trailing `*' as the BONUS marker: strip
% the star, keep the number in \CurrentProblemPoints, and raise \ifCurrentProblemBonus
% (global -- the problem env reads it in a later group). Plain values pass straight
% through. The per-PART `*' (points={2,3,1*}) is handled in \ExPart instead, since the
% list is stored element-by-element and each part is interpreted as it renders.
\newcommand{\bonus@scalar}[1]{%
  \IfEndWith{#1}{*}%
    {\StrGobbleRight{#1}{1}[\bonus@core]%
     \global\let\CurrentProblemPoints\bonus@core
     \global\CurrentProblemBonustrue}%
    {\gdef\CurrentProblemPoints{#1}}%
}
% Broadcast form: every part of a case-2 problem is worth the same #1.
\define@key{eximport}{pointseach}{%
  \global\PartsEachModetrue
  \gdef\CurrentPartEach{#1}%
}
% Per-part workspaces (case-2): workspaces={1,2,3} -> a \workspace[k] after the
% k-th \qpart. ALWAYS a positional list (one entry per part), so -- unlike points
% -- it needs no comma-branch: even a single-part workspaces={5} is a one-element
% list. See the case-2 WORKSPACES block in the POINTS section and \ExEmitWorkspace.
\define@key{eximport}{workspaces}{\ExercisesParseWorkspaceList{#1}}
\define@key{eximport}{nocount}[true]{\gdef\CurrentProblemCounts{0}}
\define@key{eximport}{hint}[true]{\gdef\CurrentProblemHint{on}}
\define@key{eximport}{nohint}[true]{\gdef\CurrentProblemHint{off}}
\define@key{eximport}{number}{\gdef\CurrentProblemNumber{#1}}
\define@key{eximport}{desc}{\gdef\CurrentProblemDesc{#1}}
% `noprint' is the flag form (matching nocount/nohint); `print=false' the value
% form, for toggling from a variable. Anything but "false" reads as true.
\define@key{eximport}{noprint}[true]{\global\CurrentProblemPrintfalse}
\define@key{eximport}{print}[true]{%
  \ifstrequal{#1}{false}{\global\CurrentProblemPrintfalse}{\global\CurrentProblemPrinttrue}}
\define@key{eximport}{checkin}[true]{\global\checkinmodetrue}

\newcommand{\importproblem@reset}{%
  \gdef\CurrentProblemPoints{}%
  \gdef\CurrentProblemCounts{1}%
  \gdef\CurrentProblemHint{inherit}%
  \global\Ex@hintseenfalse

  \gdef\CurrentProblemNumber{}%
  \gdef\CurrentProblemDesc{}%
  \global\CurrentProblemPrinttrue
  \global\checkinmodefalse
  \global\CurrentProblemBonusfalse
  % Case-2 multipart points (\ifPartsSeen is per-PROBLEM, reset there, not here).
  \global\PartsListModefalse
  \global\PartsEachModefalse
  \gdef\CurrentPartEach{}%
  \gdef\CurrentPartCount{0}%
  % Case-2 per-part workspaces.
  \global\WorkspacesModefalse
  \gdef\CurrentWSCount{0}%
}
% Parse the optional argument. The lone-value SHORTHAND covers a bare integer ([5]
% = points=5) and a bare bonus ([2*] = points=2*); both route through \bonus@scalar
% (which strips a `*' and raises the bonus flag). Anything else -- a real key=value
% list, or a token merely ending in `*' that is not <int>* -- goes to \setkeys.
\newcommand{\importproblem@opts}[1]{%
  \IfInteger{#1}%
    {\bonus@scalar{#1}}%
    {\IfEndWith{#1}{*}%
       {\StrGobbleRight{#1}{1}[\bonus@core]%
        \IfInteger{\bonus@core}{\bonus@scalar{#1}}{\setkeys{eximport}{#1}}}%
       {\setkeys{eximport}{#1}}}%
}
% ---- Consistency warnings (warnings, NOT errors) ---------------------------
% The guarded combinations all COMPILE and even render plausibly -- the danger
% is that the page silently stops saying what the source says (points counted
% but never shown, a spec quietly ignored, a requested hint that cannot appear).
% Anything that would corrupt the bookkeeping outright is an error elsewhere;
% these are the one-notch-down cases. Deliberately NOT warned: presentation keys
% a class ignores by design (points= under LectureNotes, number=/desc= under
% Assessment) -- that cross-context tolerance is the point of the extrinsic model.
%
% checkin + a points spec: check-in mode suppresses the problem heading (the box
% header is the label) -- which is exactly where a class prints the number and
% the marks. So the points can never display, yet counted points still enter the
% total: the cover's total stops matching the visible marks.
\newcommand{\Ex@warn@checkinpoints}{%
  \PackageWarning{Exercises}%
    {checkin suppresses the problem heading, so its points can\MessageBreak
     never display -- but counted points still enter the total.\MessageBreak
     Drop the points spec, or the checkin key}}

% The import is wrapped in the check-in box only when `checkin' is set -- the box
% (\CheckinBox@begin/@end) is defined in the MULTIPLE CHOICE section. Splitting
% the box's begin/end across \import is fine: \import introduces no group that
% would break the environment nesting.
\NewDocumentCommand{\importproblem}{O{} m m}{%
  \importproblem@reset
  \importproblem@opts{#1}%
  \ifCurrentProblemPrint
    % Consistency warnings (see the block above). Points spec = a scalar OR
    % either case-2 mode; conflicting case-2 specs = list AND broadcast at once
    % (the positional list wins in \ExPart, so pointseach would be ignored).
    \ifcheckinmode
      \ifdefempty{\CurrentProblemPoints}
        {\ifPartsListMode\Ex@warn@checkinpoints\else
           \ifPartsEachMode\Ex@warn@checkinpoints\fi\fi}
        {\Ex@warn@checkinpoints}%
    \fi
    \ifPartsListMode\ifPartsEachMode
      \PackageWarning{Exercises}%
        {both points={...} and pointseach given; the positional\MessageBreak
         list wins and pointseach is ignored}%
    \fi\fi
    \ifcheckinmode\CheckinBox@begin\fi
    \import{#2}{#3}%
    \ifcheckinmode\CheckinBox@end\fi
    % [hint] promised this problem's hint in EVERY build -- if the file carries
    % no hint environment at all, that promise is silently broken; say so.
    \ifdefstring{\CurrentProblemHint}{on}{%
      \ifEx@hintseen\else
        \PackageWarning{Exercises}%
          {hint forced on, but `#3' contains no hint\MessageBreak
           environment -- no hint will show in any build}%
      \fi}{}%
  \fi
  \importproblem@reset
}
% \importcheckin[OPTS]{DIR}{FILE} -- shorthand for \importproblem[checkin, OPTS].
% OPTS is key=value only (points make no sense on an ungraded notes check-in, so
% the lone-integer shorthand is deliberately not offered here); `desc' is the
% usual one, e.g. \importcheckin[desc={from APEX}]{...}{...}.
\NewDocumentCommand{\importcheckin}{O{} m m}{%
  \ifblank{#1}{\importproblem[checkin]{#2}{#3}}{\importproblem[checkin, #1]{#2}{#3}}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% FACT IMPORT
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \importfact[number={2.1}, desc={from APEX}]{DIR}{FILE} -- the fact-bank
% counterpart to \importproblem. A "fact" is a bare snippet (a definition, a
% formula) with no structure of its own, so -- unlike \importproblem -- there is
% NO points/checkin/hint/print bookkeeping: the wrapper just \imports the file.
% Its optional keys carry provenance (number and desc, the same intrinsic pair
% find-facts injects) into \CurrentFact... registers, and by default it renders
% NOTHING extra -- an imported fact stays bare, as the fact files promise. A
% document that DOES want the provenance shown -- a formula sheet listing "Power
% Rule ... Sec 2.1" -- redefines the \ShowFactMeta hook to typeset from those
% registers. This mirrors the old ProblemMeta margin display (removed
% 2026-07-18): the metadata is captured and available, never silently dropped,
% but display is opt-in.
%
% Kept here beside \importproblem because this package already owns the import
% wrappers and everything \importfact needs (import, keyval) is already loaded --
% no dependency on FactMeta.sty, so self-containment holds. If a lightweight
% formula-sheet class ever wants \importfact WITHOUT the problem/solution
% machinery, lift this block into a small Facts.sty and load that instead.
\define@key{eximportfact}{number}{\gdef\CurrentFactNumber{#1}}
\define@key{eximportfact}{desc}  {\gdef\CurrentFactDesc{#1}}
\newcommand{\importfact@reset}{%
  \gdef\CurrentFactNumber{}%
  \gdef\CurrentFactDesc{}%
}
% The opt-in provenance hook: empty by default so an imported fact renders bare.
% \renewcommand\ShowFactMeta{...} (e.g. in a formula-sheet preamble) to print
% from \CurrentFactNumber / \CurrentFactDesc. Runs before the fact body.
\newcommand{\ShowFactMeta}{}
\NewDocumentCommand{\importfact}{O{} m m}{%
  \importfact@reset
  \setkeys{eximportfact}{#1}%
  \ShowFactMeta
  \import{#2}{#3}%
  \importfact@reset
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% A run-in bold heading "Problem N." then the body, matching the content's
% existing \textbf{Problem.} style but numbered, with the import-time points (if
% any) after it. \refstepcounter (not \stepcounter) so \label inside a problem
% points at the problem: \ref gives its number.
%
% The counter is flat and document-wide: each import of a problem file steps it,
% so a set of five imported problems numbers 1..5. To restart numbering per
% section, a document can \counterwithin{problem}{section}; to reset equation
% numbers per problem, \counterwithin{equation}{problem} -- neither is imposed
% here (they surprise as often as they help).
%
% The end code clears the points globally (\gdef): \import does not group its
% contents, but clearing globally is robust regardless and enforces consume-once.
\newcounter{problem}

% Grouped subquestions (see the PROBLEM GROUPS section). Inside a \problemgroup
% each imported problem renders as a lettered PART -- "(a)", "(b)" -- instead of
% "Problem N.". The flag below, set locally true by the group, is what the problem
% environment branches on; the same atomic file renders either way, so nothing in
% the library changes. The counter resets whenever `problem' steps (so each group,
% and each top-level problem, starts its letters at (a)); \thesubproblem carries
% the parent number so a \ref to a part reads "N(a)" (NOT via \p@subproblem --
% see the note at \thesubproblem below for why that route breaks).
\newif\ifinproblemgroup
% Choose-N-of-M grouping (see the PROBLEM CHOICE section). When active, a member's
% points are NOT added to the exam total (the group adds select*points once), the
% shared per-member value is filled into its margin mark, and the generated
% instruction is printed above it. Forward-declared here because the problem env
% (below) reads it; the machinery lives in its own section further down.
\newif\ifinproblemchoice
% Like \ifExFirstPart for case-2: the first part of a \problemgroup runs into the
% stem line, the rest each break. Set by \problemgroup, consumed by the problem env.
\newif\ifGroupFirstPart
\newcounter{subproblem}[problem]
% How a part is lettered -- the counter-formatting command applied to `subproblem'.
% Class/course-overridable (the same idiom as \ProblemLabelWord): \alph -> (a)(b)(c)
% (the default), \Alph -> (A)(B)(C), \roman -> (i)(ii)(iii), etc. Used in ALL THREE
% places a part label appears -- the \ref text (\thesubproblem), the case-2 \qpart
% run-in, and the case-1 \problemgroup run-in -- so the printed "(a)" and a \ref's
% "N(a)" always agree. Set once, e.g. \renewcommand{\QPartLabelFormat}{\Alph} in
% course-vocab.tex or a class.
\newcommand{\QPartLabelFormat}{\alph}
% \thesubproblem carries the parent number ("4(a)") so a \ref to a part reads
% "4(a)" -- the same nesting trick as \theequation under a section. The prefix
% must live INSIDE \thesubproblem, not in \p@subproblem: routed through \p@ the
% \number scan inside \arabic{problem} swallows the following token and the
% letter is lost. The heading prints just "(a)" via \QPartLabelFormat directly
% (below), so the two representations differ on purpose -- short label, full ref.
\renewcommand{\thesubproblem}{\theproblem(\QPartLabelFormat{subproblem})}

% ---- Heading: class-overridable PRESENTATION -------------------------------
% A problem file is context-neutral -- \begin{problem} names no label of its own,
% because the SAME file is a numbered "Q" on a test and an "Example" in a lecture.
% The consuming class decides the look through two hooks, the same idiom as
% Titling's \TitleColor and Hyperlinks' \LinkColor:
%
%   \ProblemLabelWord     the noun -- "Problem" (default), "Q", "Example".
%   \ProblemNumberText    the FORMATTED number, "Problem N" / "Q N" / "Q N" (tight).
%                         One macro so the standalone heading and the group stem
%                         can never disagree; a class overrides it if the separator
%                         differs (Assessment wants "QN", no space).
%   \ProblemHeadingFormat typesets a TOP-LEVEL problem's whole heading. It runs
%                         AFTER the counter is stepped and (for a counted problem)
%                         the points are already in the total, so it is pure
%                         presentation -- read \ProblemNumberText / \CurrentProblemPoints
%                         and place them inline or in the margin, with no risk to
%                         the count. Default: run-in "Problem N." + inline points.
%   \ProblemGroupHeadingFormat{STEM}  the same, for a \problemgroup's numbered stem.
%
%   Assessment.cls overrides these to "Q N" over a points \fbox hung in the left margin;
%   LectureNotes.cls to a run-in "Example." (+ optional literal number / desc).
\newcommand{\ProblemLabelWord}{Problem}
\newcommand{\ProblemNumberText}{\ProblemLabelWord\ \theproblem}
\newcommand{\ProblemHeadingFormat}{%
  \noindent\textbf{\ProblemNumberText.}%
  \ifdefempty{\CurrentProblemPoints}{}{\ProblemPointsMark{\CurrentProblemPoints}}%
  \quad
}
% No trailing \par: the first part runs into this stem line (the problem env
% suppresses its own leading break for the first part). #1 is usually empty.
\newcommand{\ProblemGroupHeadingFormat}[1]{%
  \noindent\textbf{\ProblemNumberText.}\quad\ignorespaces#1%
}

% The environment separates BOOKKEEPING (counter + running total -- never
% overridable, so a restyled heading can never disturb the point count) from
% PRESENTATION (the heading). A part inside a \problemgroup always renders as a
% lettered "(a)" run-in -- the group, not the class, owns that layout -- while a
% top-level problem goes through \ProblemHeadingFormat.
\newenvironment{problem}{%
  % Leading break: a top-level problem always breaks from what precedes it; a
  % grouped part breaks EXCEPT the first, which runs into the group's stem line.
  \ifinproblemgroup
    \ifGroupFirstPart\global\GroupFirstPartfalse\else\par\fi
  \else
    \par
  \fi
  % --- Bookkeeping.
  \ifinproblemgroup\refstepcounter{subproblem}\else\refstepcounter{problem}\fi
  % Case-2: cleared here (per problem) so \end below can tell whether a `qparts'
  % environment actually ran to consume any multipart points spec.
  \global\PartsSeenfalse
  % A literal import-time number (\importproblem's `number' key) replaces the
  % counter's value as the \label/\ref text -- so a problem shown as the text's
  % "2.1.8" also refs as "2.1.8". The counter was still stepped just above
  % (harmless: a notes class never prints it); only the label text changes.
  % Empty (the usual case) keeps the counter's value.
  \ifdefempty{\CurrentProblemNumber}{}{\protected@edef\@currentlabel{\CurrentProblemNumber}}%
  % \refstepcounter sets \@currentlabel LOCALLY, but this environment is a group
  % and the problem body arrives via \import -- so a \label written next to the
  % \importproblem (outside the group) would otherwise capture the *enclosing*
  % label, not this problem's. Globalise it so \label works from the assembly
  % file. hyperref already makes its anchor (\@currentHref) global, so this keeps
  % the ref text and the hyperlink target in sync.
  \global\let\@currentlabel\@currentlabel
  \ifinproblemchoice
    % Choose-N-of-M member: fill the group's shared value for THIS member's margin
    % mark (members carry no points= of their own), and do NOT add to the total --
    % the group adds select*value ONCE at \end{problemchoice}. Count the member for
    % the select<=M guard.
    %
    % A member that DOES carry its own points= is flagged: the group's shared
    % value is the one source, so the member's own would either be silently
    % clobbered (group value set) or shown-but-never-counted (group value
    % empty) -- both quiet divergences between the page and the total.
    \ifdefempty{\CurrentProblemPoints}{}{%
      \PackageWarning{Exercises}%
        {problemchoice member carries its own
         points=\CurrentProblemPoints, which is never\MessageBreak
         counted -- declare one shared points= on the group instead}}%
    \ifdefempty{\pchoice@val}{}{\def\CurrentProblemPoints{\pchoice@val}}%
    \stepcounter{pchoicemembers}%
  \else
    \ifdefempty{\CurrentProblemPoints}{}{%
      % A BONUS problem (points=2*) is off the total, like nocount, but announced by
      % the heading's bonus marker instead of quietly. Otherwise the nocount flag decides.
      \ifCurrentProblemBonus\else
        \ifdefstring{\CurrentProblemCounts}{1}{\addtocounter{totalpoints}{\CurrentProblemPoints}}{}%
      \fi
    }%
  \fi
  % --- Presentation.
  \ifinproblemgroup
    \noindent\textbf{(\QPartLabelFormat{subproblem})}%
    \ifdefempty{\CurrentProblemPoints}{}{\ProblemPointsMark{\CurrentProblemPoints}}%
    \quad
  \else
    % A choose-N-of-M member prints the generated instruction above its heading, so
    % the "choose 2 of these" context repeats on every question (page-break safe).
    \ifinproblemchoice\pchoice@emit\fi
    % Check-in mode suppresses the problem's own heading -- the enclosing "Check
    % In" box title is the label, so an "Example."/"Q N." here would double up.
    \ifcheckinmode\else\ProblemHeadingFormat\fi
  \fi
  \ignorespaces
}{%
  \par
  % A case-2 points spec must be consumed by a `qparts' environment. If one was
  % given (positional list or broadcast) but no parts ran, the points would
  % silently vanish -- flag it rather than lose them.
  \ifPartsSeen\else
    \ifPartsListMode
      \PackageError{Exercises}%
        {points={...} list given but this problem has no `qparts' environment}%
        {Wrap the dependent parts in \string\begin{qparts}...\string\end{qparts},
         or drop the list.}%
    \fi
    \ifPartsEachMode
      \PackageError{Exercises}%
        {pointseach given but this problem has no `qparts' environment}%
        {Wrap the dependent parts in \string\begin{qparts}...\string\end{qparts},
         or drop pointseach.}%
    \fi
    \ifWorkspacesMode
      \PackageError{Exercises}%
        {workspaces given but this problem has no `qparts' environment}%
        {Wrap the dependent parts in \string\begin{qparts}...\string\end{qparts},
         or drop workspaces.}%
    \fi
  \fi
  \gdef\CurrentProblemPoints{}\gdef\CurrentProblemCounts{1}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM GROUPS (subquestions)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \begin{problemgroup}{STEM} ... \end{problemgroup} -- a numbered "Problem N."
% carrying a shared instruction (STEM), under which each imported problem prints
% as a lettered part (a), (b), .... This is the ASSEMBLY-TIME wrapper: the parts
% stay atomic one-problem files in the bank and are pulled in with \importproblem
% exactly as anywhere else; the group only changes how they render. Use it for
% independent items sharing an instruction ("Evaluate the following integrals:").
% Genuinely dependent parts ("Let f(x)=...; (a)... (b)...") are ONE problem and
% belong in one file -- not this.
%
% Points are per-part (each \importproblem[..] inside carries its own), so the
% group takes no point value; the grand total sums the parts as usual, and a part
% may be starred (\importproblem*) to sit off the books.
%
% Mechanism: the environment is a TeX group, so \inproblemgrouptrue is undone
% automatically at \end -- the flag falls back to false for whatever follows. The
% parts are NOT indented (they sit flush at the text margin, matching case-2).
% \GroupFirstParttrue lets the problem env run the FIRST part into the stem line
% (see the problem env's leading-break branch); the rest each break. The trailing
% \par flushes the last part.
\newenvironment{problemgroup}[1]{%
  \par\refstepcounter{problem}%
  \ProblemGroupHeadingFormat{#1}%
  \inproblemgrouptrue
  \global\GroupFirstParttrue
  % Swallow the source whitespace before the first \importproblem, else the first
  % part (which runs into the stem line) picks up a phantom interword indent.
  \ignorespaces
}{%
  \par
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM PARTS (case 2 -- dependent parts in ONE file)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \begin{qparts} \qpart ... \qpart ... \end{qparts} -- the internal part list of a
% SINGLE problem whose parts genuinely depend on a shared stem ("Let f(x)=...;
% (a) find f', (b) the critical points, (c) classify them"). Unlike a
% \problemgroup (case 1, which ASSEMBLES independent atomic files under a lettered
% wrapper), these parts are ONE problem in ONE file -- so they live INSIDE the
% `problem' body, not as separate imports:
%
%   \importproblem[points={1,1,2}]{DIR}{classify-critical-points.tex}
%   % and in that file:
%   \begin{problem}
%     Let $f(x)=x^3-3x$.
%     \begin{qparts}
%       \qpart Find $f'$.          % 1 pt
%       \qpart The critical points. % 1 pt
%       \qpart Classify them.       % 2 pts
%     \end{qparts}
%   \end{problem}
%
% Points come from the IMPORT site (points={1,1,2} positional, pointseach=N
% broadcast -- see the POINTS section), so the file's \qpart's carry no weights and
% the extrinsic rule holds. Each part letters "(a)(b)(c)" by reusing the
% `subproblem' counter -- so a \ref to a part reads "7(a)", exactly like a case-1
% part -- and drops its marks through the shared \ProblemPointsFormat hook (inline
% by default, right-margin under Assessment.cls). With NO points spec the parts still
% letter, just unmarked (a valid ungraded / notes use).
%
% The item command is \qpart, NOT \part. A dedicated name (rather than locally
% redefining LaTeX's sectioning \part) keeps the real \part untouched everywhere
% AND stops editors from folding these as document parts (vim treats \part as a
% sectioning command). \qpart is \let to \ExPart LOCALLY in the begin-code, so it
% is defined only between \begin{qparts} and \end{qparts} -- using it outside gives a
% clean "undefined" error. (An implicit assumption, not defended against: a \qpart
% hidden inside a user macro/loop would not be counted -- a non-issue for
% hand-authored case-2 files.)
%
% Safeguards: in positional mode the part count must equal the list length -- too
% few is caught at \end{qparts}, too many the instant a part outruns the list; a
% non-integer value errors before it can reach \addtocounter/\ifnum; and a points
% spec with no `qparts' at all is caught in \end{problem} (see the PROBLEM env).
\newenvironment{qparts}{%
  \global\PartsSeentrue
  \global\ExFirstParttrue
  \let\qpart\ExPart
  % Swallow the source whitespace between \begin{qparts} and the first \qpart.
  % The first part runs into the heading line (horizontal mode), so that space
  % would otherwise become a real interword space -- a ~3.6pt phantom indent on
  % the first item only (later parts \par first, where leading space is dropped).
  \ignorespaces
}{%
  \par
  % The LAST part's workspace: parts 1..n-1 were emitted as each next \qpart began
  % (in \ExPart), so the final part's room is emitted here -- after its full content
  % (its inline solution too), the same rule as every other part.
  \ifWorkspacesMode\ifnum\value{subproblem}>0 \ExEmitWorkspace{\arabic{subproblem}}\fi\fi
  % Positional mode: the number of parts seen (subproblem's value) must equal the
  % list length. Fewer parts than values lands here; more parts errored earlier.
  \ifPartsListMode
    \ifnum\value{subproblem}=\CurrentPartCount\relax\else
      \PackageError{Exercises}%
        {points list has \CurrentPartCount\space value(s) but the problem has
         \arabic{subproblem}\space part(s)}%
        {The points={...} list length must equal the number of \string\qpart s.}%
    \fi
  \fi
  % Same one-entry-per-\qpart contract for the workspaces list.
  \ifWorkspacesMode
    \ifnum\value{subproblem}=\CurrentWSCount\relax\else
      \PackageError{Exercises}%
        {workspaces list has \CurrentWSCount\space value(s) but the problem has
         \arabic{subproblem}\space part(s)}%
        {The workspaces={...} list length must equal the number of \string\qpart s.}%
    \fi
  \fi
}

% Emit part #1's handwriting workspace, if a `workspaces' list was given at the
% import. An entry of 0 or empty means "no room for this part". \workspace lives
% in Workspace.sty and may be ABSENT under a class that does not load it (e.g.
% CourseDocument): guard with \ifdef so a workspaces list is simply inert there,
% keeping this package self-contained (mirrors the \WSZeroHeight fallback). Called
% as each NEXT part begins and once at \end{qparts}, so a part's room always
% follows its full content -- including any inline \begin{solution}, which in
% overlay mode paints DOWN into exactly this reserved space.
\newcommand{\ExEmitWorkspace}[1]{%
  \ifWorkspacesMode
    \edef\ExThisWS{\csuse{ExWs@#1}}%
    \ifdefempty{\ExThisWS}{}{%
      \ifdefstring{\ExThisWS}{0}{}{%
        % Expand \ExThisWS into the optional arg BEFORE \workspace scans it: its
        % keyword test (\ifstrequal{...}{halfpage}) does not expand, so a passed
        % macro would miss the keyword branch and fall through to the numeric one.
        \ifdef{\workspace}{\expandafter\workspace\expandafter[\ExThisWS]}{}%
      }%
    }%
  \fi
}

% One \qpart: step the sub-counter (letters (a),(b),... and makes \ref read
% "N(a)"), resolve this part's points from whichever mode is active, add them to
% the running total, then set the run-in "(a)" label + marks. Bound to \qpart only
% inside `qparts'.
\newcommand{\ExPart}{%
  % Before this part opens, close out the PREVIOUS one: emit its workspace (parts
  % 1..k-1 here, the final part at \end{qparts}). \value{subproblem} is still the
  % previous part's index -- this part is not counted until \refstepcounter below --
  % so 0 means there is no previous part (this is the first \qpart), nothing to emit.
  \ifnum\value{subproblem}>0 \ExEmitWorkspace{\arabic{subproblem}}\fi
  % The FIRST part runs into the stem/heading line (no break); every later part
  % breaks to its own line. To force the first part onto its own line instead
  % (e.g. after a long stem), leave a blank line before \begin{qparts} -- that \par
  % puts us in vertical mode, so the run-in "(a)" below starts a fresh line anyway.
  \ifExFirstPart\global\ExFirstPartfalse\else\par\fi
  \refstepcounter{subproblem}%
  % Resolve this part's value by mode. Positional: the k-th list element (error if
  % the parts outrun the list). Broadcast: the fixed per-part value. Neither:
  % unweighted -- a bare parts list with no points spec, letters but no marks.
  \ifPartsListMode
    \ifnum\value{subproblem}>\CurrentPartCount\relax
      \PackageError{Exercises}%
        {more \string\qpart s than points values (list has \CurrentPartCount)}%
        {Add values to points={...} or remove the extra \string\qpart.}%
      \let\ThisPartPts\@empty
    \else
      \edef\ThisPartPts{\csuse{ExPartPts@\arabic{subproblem}}}%
    \fi
  \else
    \ifPartsEachMode
      \let\ThisPartPts\CurrentPartEach
    \else
      \let\ThisPartPts\@empty
    \fi
  \fi
  % A trailing `*' on this part's value (points={2,3,1*}, or pointseach=2*) marks it
  % BONUS: strip the star and flag it, so the part stays OFF the total and renders
  % through the bonus marker. Reuses the scalar flag \ifCurrentProblemBonus LOCALLY,
  % so \ProblemPointsMark dispatches a part exactly like a whole problem; the local
  % assignment reverts at \end{qparts}, and is cleared first so a plain part following
  % a bonus one is not itself bonus.
  \CurrentProblemBonusfalse
  \ifdefempty{\ThisPartPts}{}{%
    \IfEndWith{\ThisPartPts}{*}%
      {\StrGobbleRight{\ThisPartPts}{1}[\ThisPartPts]\CurrentProblemBonustrue}{}%
  }%
  % Guard the integer contract (\ifnum + \addtocounter both need one) before the
  % value can reach either: a bad value errors and is dropped so nothing crashes. A
  % bonus part is shown but NOT added to the total.
  \ifdefempty{\ThisPartPts}{}{%
    \IfInteger{\ThisPartPts}%
      {\ifCurrentProblemBonus\else\addtocounter{totalpoints}{\ThisPartPts}\fi}%
      {\PackageError{Exercises}{part points `\ThisPartPts' is not an integer}%
        {Part point values must be whole numbers.}\let\ThisPartPts\@empty}%
  }%
  % Presentation: run-in "(a)" + this part's marks (shared dispatch), then the prompt.
  \noindent\textbf{(\QPartLabelFormat{subproblem})}%
  \ifdefempty{\ThisPartPts}{}{\ProblemPointsMark{\ThisPartPts}}%
  \quad\ignorespaces
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM CHOICE (choose N of M)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% \begin{problemchoice}[select=2, points=5] ... \end{problemchoice} -- the
% "answer any 2 of Questions 7-9" pattern, with ALL the bookkeeping automated. The
% body is a run of ordinary \importproblem members (standalone "Q N", NOT lettered
% parts -- so, unlike qparts/problemgroup, this does NOT touch the subproblem
% counter). Three things are automated so the author writes nothing but select/points:
%
%   * ACCOUNTING. Each member would normally add its points to the exam total;
%     inside the group they do NOT (the ambient \ifinproblemchoice flag makes the
%     problem env skip its \addtocounter). The GROUP adds select*points ONCE, so a
%     "choose 2 of 3, 5 each" block contributes 10, not 15 -- automatically, with no
%     hand-placed \nocount. Insert or delete a member and the total re-derives. This
%     is what mostly retires manual `nocount' (the other case being bonus points).
%   * THE POINT VALUE is declared ONCE here (points=5) and filled into every
%     member's margin mark, so members carry no points= of their own. "Choose N of M"
%     is only used when the alternatives are equal value, so one declaration fits.
%   * THE INSTRUCTION ("Answer any two of Questions 7-9.") is generated and printed
%     ABOVE EACH member, so the "choose 2 of these" context travels with every
%     question across page breaks (same robustness argument as a repeated
%     problemgroup instruction). The NUMBERS are cross-references -- \ref to the
%     first and last member -- so they are never typed and AUTO-UPDATE when a
%     question is inserted before the block. Cost: the usual second compile to
%     settle them (they show "??" once, exactly like \printtotalpoints; latexmk
%     reruns on the changed .aux). The wording is a class-overridable hook
%     (\ProblemChoiceInstruction), so it is one consistent phrasing per course.
%
% Members must be single-value problems: a qparts/problemgroup member adds to the
% total by a different path and would double-count. (Not guarded -- the normal use
% never nests those here.)
\newif\ifpchoicefirst        % first member drops the range's left \label; then off
\newcounter{pchoicegroup}    % unique id per \problemchoice, for its two \labels
\newcounter{pchoicemembers}  % members in the current group (the select<=M guard)
\newcommand{\pchoice@select}{}
\newcommand{\pchoice@val}{}
\newcommand{\pchoice@id}{0}
\define@key{pchoice}{select}{\def\pchoice@select{#1}}
\define@key{pchoice}{points}{\def\pchoice@val{#1}}

% Spell out a small count (the "two" in "any two of ..."); digits are the fallback
% for anything past nine. \ifcase needs an integer -- select is guarded to be one.
\newcommand{\pchoice@numword}[1]{%
  \ifcase#1 zero\or one\or two\or three\or four\or five\or six\or seven\or
    eight\or nine\else #1\fi}

% The instruction sentence -- CLASS-OVERRIDABLE presentation (same idiom as
% \ProblemHeadingFormat). #1 = select (as given); #2 = first member number,
% #3 = last member number, both \ref values (hence hyperlinks, and auto-updating).
% Restyle the wording in one place (here, or override in Assessment.cls/course-vocab.tex).
\newcommand{\ProblemChoiceInstruction}[3]{%
  \noindent\textbf{Answer any \pchoice@numword{#1} of Questions~#2--#3.}}

% Printed above each member by the problem env. On the FIRST member it also drops
% the \label the range's LEFT end reads; the RIGHT end is labelled at
% \end{problemchoice}. The \ref to that (forward) last label is "??" until the
% rerun -- the accepted two-pass cost, the same one \printtotalpoints pays.
\newcommand{\pchoice@emit}{%
  \par\addvspace{\medskipamount}%
  \ifpchoicefirst
    \global\pchoicefirstfalse
    \label{pc@\pchoice@id @first}%
  \fi
  \ProblemChoiceInstruction{\pchoice@select}%
    {\ref{pc@\pchoice@id @first}}{\ref{pc@\pchoice@id @last}}%
    \vspace{-1em}\par\nobreak
}

\newcounter{pchoicetmp}  % scratch for select*value
\NewDocumentEnvironment{problemchoice}{O{}}{%
  \par
  \stepcounter{pchoicegroup}%
  \edef\pchoice@id{\arabic{pchoicegroup}}%
  \setcounter{pchoicemembers}{0}%
  \def\pchoice@select{}\def\pchoice@val{}%
  \setkeys{pchoice}{#1}%
  \inproblemchoicetrue    % LOCAL: nested member groups see it; \end auto-clears it
  \pchoicefirsttrue
}{%
  \par
  % The range's RIGHT end: the last member's number. The problem env globalised its
  % \@currentlabel, so it is still the last member's here.
  \label{pc@\pchoice@id @last}%
  % Accounting: add select*value ONCE. Guard the integer contract before arithmetic.
  \ifdefempty{\pchoice@val}{}{%
    \ifdefempty{\pchoice@select}{%
      \PackageError{Exercises}{problemchoice: points given but no `select'}%
        {Add select=N to \string\begin{problemchoice}[...].}%
    }{%
      \IfInteger{\pchoice@select}{%
        \IfInteger{\pchoice@val}{%
          \setcounter{pchoicetmp}{\numexpr\pchoice@select*\pchoice@val\relax}%
          \addtocounter{totalpoints}{\value{pchoicetmp}}%
        }{\PackageError{Exercises}{problemchoice: points `\pchoice@val' is not an
            integer}{Point values must be whole numbers.}}%
      }{\PackageError{Exercises}{problemchoice: select `\pchoice@select' is not an
          integer}{select must be a whole number.}}%
    }%
  }%
  % Sanity: cannot choose more alternatives than are offered.
  \ifdefempty{\pchoice@select}{}{%
    \IfInteger{\pchoice@select}{%
      \ifnum\pchoice@select>\value{pchoicemembers}\relax
        \PackageError{Exercises}%
          {problemchoice: select=\pchoice@select\space but only
           \arabic{pchoicemembers}\space member(s)}%
          {select must be <= the number of \string\importproblem\space members.}%
      \fi
    }{}%
  }%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SOLUTION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% ForestGreen is a dvipsnames colour. Green reads as "answer" and stays clear of
% the course-identity colour used for headings. Named once here so it can be
% retuned in one place.
\colorlet{SolutionColor}{ForestGreen}

% The look of the solution box, factored into two pieces so its titled and plain
% (no-tab) variants share one definition (retune in a single place, the same
% one-place-to-restyle idiom as CourseBoxes' cb/... styles):
%
%   ex/answerbox={COLOUR}       the box itself -- light fill, thin frame, sharp
%                               corners, leftskip-aware width. NO tab.
%   ex/answertab={COLOUR}{WORD} the small white-on-colour tab hung over the
%                               top-left border.
%
% Composed into ex/solution (box + tab) and ex/solutionplain (box only, for
% \begin{solution}[notitle]). Splitting the tab out is what makes it suppressible:
% the plain twin simply omits it (and trims the top padding, since there is no tab
% to clear). (The hint used to reuse these pieces too; it is now a plain run-in.)
%
% parbox=false so display math and multiple paragraphs in the body set normally;
% breakable so a long body can cross a page. The tab fill is a strong tint (!80)
% so the white tab text keeps its contrast.
\tcbset{
  ex/answerbox/.style={
    enhanced, breakable, parbox=false,
    colback=#1!5, colframe=#1!60,
    sharp corners, boxrule=0.2mm,
    left=6pt, right=6pt, top=10pt, bottom=6pt,
    % Shrink the box by any active \leftskip so it never overhangs the right
    % margin. A tcolorbox defaults to width=\linewidth, but a nonzero \leftskip
    % adds glue to the line WITHOUT reducing \linewidth -- so an unshrunk box runs
    % \leftskip past the margin (a "24pt too wide" overfull). This package's own
    % environments no longer indent (parts/groups sit flush), so \leftskip is 0pt
    % here and this is just \linewidth; the guard stays for any author-set \leftskip.
    width=\dimexpr\linewidth-\leftskip\relax,
  },
  ex/answertab/.style 2 args={
    coltitle=white, colbacktitle=#1!80,
    title={\sffamily\footnotesize #2},
    % xshift aligns the tab's LABEL TEXT with the body text's left margin (the
    % tab's left edge overhangs a touch into the border), so the label reads as a
    % heading over its paragraph. Tuned to the left= paddings here; retune if those
    % change. (Use ~16pt instead to make the tab's left EDGE flush with the body.)
    attach boxed title to top left={xshift=8.5pt, yshift=-\tcboxedtitleheight/2},
    boxed title style={
      size=small, boxrule=0pt, sharp corners,
      colback=#1!70,
      top=0.5pt, bottom=0.5pt, left=1.5pt, right=1.5pt,
    },
  },
  ex/solution/.style     ={ex/answerbox=SolutionColor, ex/answertab={SolutionColor}{solution}},
  ex/solutionplain/.style={ex/answerbox=SolutionColor, top=6pt},
}

% Zero-height overlay routing. Workspace.sty (loaded by Assessment/LectureNotes) defines
% \WSZeroHeight, which in the default OVERLAY mode emits a box at zero height so it
% paints down into the reserved \workspace instead of shifting the layout; under
% \collapseworkspace it emits normally. Both the solution and hint environments route their
% box through it. Exercises stays SELF-CONTAINED: if Workspace is absent (e.g. under
% CourseDocument), this \AtBeginDocument fallback makes \WSZeroHeight a pass-through,
% so the boxes just render at normal height. \providecommand at begin-document, so
% the real definition wins whenever Workspace is loaded (before or after us).
\AtBeginDocument{\providecommand{\WSZeroHeight}[1]{#1}}

% Per-box options for \begin{solution}, keyval family `exbox' -- the same idiom as
% \importproblem's `eximport'. (The hint is a plain run-in now, not a box, so it
% takes no options.) One key for now; future per-box axes slot in as one more.
%
%   notitle   drop the corner tab, leaving just the coloured box
%
% \ifex@notitle is reset false before each box, so the option never leaks to the
% next; \setkeys errors loudly on an unknown key (a typo), as eximport does.
\newif\ifex@notitle
\define@key{exbox}{notitle}[true]{\ex@notitletrue}

% \NewEnviron captures the whole body as \BODY. When solutions are OFF we simply
% never emit \BODY -- the clean way to drop an environment's contents, and the
% same pattern IfThenBoxes.sty already uses for its solution-only boxes. A plain
% \newenvironment with \ifsolutions...\fi wrapped around the delimiters is
% fragile (the body is still scanned, and the \fi lands in the wrong group); this
% is not. When solutions are ON, the body is set inside the ex/solution box --
% or ex/solutionplain (no tab) for \begin{solution}[notitle].
\NewEnviron{solution}[1][]{%
  \ifsolutions
    \ex@notitlefalse
    \setkeys{exbox}{#1}%
    \par
    \ifex@notitle
      \WSZeroHeight{\begin{tcolorbox}[ex/solutionplain]\BODY\end{tcolorbox}}%
    \else
      \WSZeroHeight{\begin{tcolorbox}[ex/solution]\BODY\end{tcolorbox}}%
    \fi
  \fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HINT
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% A hint is a LIGHT run-in aside, NOT a box: a new line, a "HINT:" label, then the
% hint text in italics. Deliberately plainer than the solution (a boxed answer key)
% -- a hint is a small nudge, not the answer. Inline where written (NOT collected at
% the end, as xsim's hint model does). Shown in the hints build via the independent
% \ifhints toggle.
%
% NOT zero-height (unlike the solution overlay): a hint is student-facing help shown
% in the hints build and should push content down NORMALLY, so it does not route
% through \WSZeroHeight and is unaffected by \collapseworkspace.
%
% \HintLabel is the single styling knob -- the fully-formatted run-in label. The
% body that follows is italicised by the environment. TWEAK the label look here
% (e.g. wrap in \textcolor for a warm cue; kept plain bold for a light touch).
\newcommand{\HintLabel}{\textbf{HINT:}}

% Three-state visibility (see \CurrentProblemHint): the per-import hint/nohint keys
% force this hint on/off; "inherit" (the default, and every non-\importproblem
% context) follows the document \ifhints toggle. \showhint collapses the three
% states to one boolean the emit-or-drop below reads.
\newif\ifshowhint
\NewEnviron{hint}{%
  % Record that the imported file HAS a hint, shown or not -- \importproblem
  % reads this to warn when [hint] is forced on a hint-less file.
  \global\Ex@hintseentrue
  \showhintfalse
  \ifdefstring{\CurrentProblemHint}{on}{\showhinttrue}{%
    \ifdefstring{\CurrentProblemHint}{off}{}{\ifhints\showhinttrue\fi}%
  }%
  \ifshowhint
    \par\smallskip
    \noindent\HintLabel\ {\itshape\ignorespaces\BODY}\par
  \fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% MULTIPLE CHOICE (choices list)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% An MC question is NOT a separate problem type -- it is a normal \begin{problem}
% (numbered, points via \importproblem, filterable via \ProblemMeta tags) whose
% body carries a choices list. ONE environment, three layouts via an optional arg:
%
%   \begin{choices}          one option per line   (default; long options)
%   \begin{choices}[onepar]  options inline         (short: Even/Odd/Neither/Both)
%   \begin{choices}[grid]    a \ChoicesGridCols-wide grid, row-major (default 2)
%
%   \begin{problem}
%     What is the domain of ...?
%     \begin{choices}
%       \choice{$\{x : x\ge -1\}$}
%       \choice[correct]{$\{x : x\ge -1,\ x\ne 7\}$}
%       ...
%     \end{choices}
%   \end{problem}
%
% Options are lettered (A), (B), .... A \choice is marked the key by the optional
% argument -- \choice[correct]{...} -- so swapping which option is correct is an
% in-place edit, no command rename. (Any value in the bracket means "key"; the
% word `correct' is just the readable spelling.) The key is boxed ONLY in a
% solutions build (gated by \ifsolutions, the same toggle as \begin{solution}), so
% the answer never leaks; several may be marked (select-all-that-apply).
%
% The grid is built from \parbox cells laid with \hfill/\par, NOT a tabular: a
% macro (\choice) that emits alignment tokens & / \\ from inside conditionals
% breaks both tabular and tabularray (they scan for those tokens); \hfill and \par
% are safe in conditionals, need no table package, and still wrap long options.
\newcounter{choice}
\newcommand{\ChoicesGridCols}{2}   % columns in [grid]; \renewcommand to change
\newcount\choice@col               % column position within the current grid row
\newlength{\choice@gridwidth}
\newcommand{\choice@layout}{stacked}

% ---- Choice label style ------------------------------------------------------
% Every layout renders its "[A]" through this ONE hook, so the label style is a
% single knob. Default: the letter in SQUARE brackets -- round brackets are already
% spoken for by (parts) and (points), and the Crowdmark answer sheet uses rectangular
% bubbles, so [A][B] keeps MC options visually distinct from both. Check-in mode
% (\ifcheckinmode) swaps in the colored flashcard boxes instead.
\newcommand{\ChoiceLabelFormat}[1]{[#1]}

% The check-in palette: one background per letter, white text on the darker three
% for contrast (the quarry's flashcard colors, kept exactly). Only A-E are
% defined -- a check-in caps at five options; a sixth+ falls back to plain "(F)".
\definecolor{checkinA}{RGB}{247,244,58}
\definecolor{checkinB}{RGB}{123,104,238}
\definecolor{checkinC}{RGB}{247,58,241}
\definecolor{checkinD}{RGB}{118,247,58}
\definecolor{checkinE}{RGB}{247,165,58}
\newcommand{\checkin@lab}[3]{% #1 background color, #2 text color, #3 letter
  \begingroup\setlength{\fboxsep}{8pt}%
  \colorbox{#1}{\sffamily\bfseries\textcolor{#2}{#3}}\endgroup}
\@namedef{checkin@lab@A}{\checkin@lab{checkinA}{black}{A}}
\@namedef{checkin@lab@B}{\checkin@lab{checkinB}{white}{B}}
\@namedef{checkin@lab@C}{\checkin@lab{checkinC}{white}{C}}
\@namedef{checkin@lab@D}{\checkin@lab{checkinD}{black}{D}}
\@namedef{checkin@lab@E}{\checkin@lab{checkinE}{white}{E}}
\newcommand{\CheckinChoiceLabel}[1]{%
  \edef\checkin@L{#1}% expand \Alph{choice} down to the bare letter (A, B, ...)
  \@ifundefined{checkin@lab@\checkin@L}{[#1]}{\@nameuse{checkin@lab@\checkin@L}}}

% The "Check In" frame (see \importcheckin). Deliberately plain -- a thin grey
% rule, no fill -- because the colored labels inside carry the visual identity.
% NON-breakable: a check-in should not split across a page. NO title bar; instead
% a run-in sans-serif all-caps "CHECK IN:" header at the top of the box, with
% \importproblem's `desc' appended in parentheses if given.
\tcbset{ex@checkin/.style={%
  enhanced, sharp corners,
  boxrule=2pt, colframe=black!55, colback=white,%  <-- box thickness: raise boxrule
  left=1em, right=1em, top=0.6em, bottom=0.6em}}
% Two tunable check-in gaps -- change the values here:
%   \CheckinHeaderSkip  vertical space under "CHECK IN:", before the problem stem
%   \CheckinBodySkip    vertical space after the stem, before the choices list
\newcommand{\CheckinHeaderSkip}{\medskipamount}
\newcommand{\CheckinBodySkip}{\bigskipamount}
\newcommand{\CheckinBox@header}{%
  {\sffamily\bfseries CHECK IN%
    \ifdefempty{\CurrentProblemDesc}{}{\ \mdseries(\CurrentProblemDesc)\bfseries}%
    :}\par\nobreak\vspace{\CheckinHeaderSkip}}
\newcommand{\CheckinBox@begin}{\begin{tcolorbox}[ex@checkin]\CheckinBox@header}
\newcommand{\CheckinBox@end}{\end{tcolorbox}}

% The shared "this is the answer" cue: a tight SolutionColor frame + light fill
% around the content, via \fcolorbox so no tcolorbox is needed. ONE macro (plus
% its two dimension knobs) serves every inline answer cue -- the boxed correct
% MC option below AND the matching env's "->[C]" annotation (\MatchKeyFormat) --
% so the two can never drift apart. SolutionColor is defined in the SOLUTION
% section above. NB \fcolorbox is an \mbox: content will not line-break inside
% (fine for the short things boxed here). Retune the knobs to restyle both cues.
\newcommand{\SolutionCueRule}{0.2mm}
\newcommand{\SolutionCueSep}{2pt}
\newcommand{\SolutionCueBox}[1]{%
  \begingroup
    \setlength{\fboxrule}{\SolutionCueRule}\setlength{\fboxsep}{\SolutionCueSep}%
    \fcolorbox{SolutionColor}{SolutionColor!8}{#1}%
  \endgroup}

% How the key is boxed in a solutions build: the shared cue above, forced down
% to the bare option's metrics.
%
% ZERO-FOOTPRINT (the overlay contract): the box must occupy EXACTLY the same
% height/depth/width as the bare option text, so a choices list lays out identically
% whether the key is boxed (solutions build) or not (student build) -- otherwise the
% ~7pt the \fboxsep+\fboxrule add on each side would make the solutions list taller
% and shift a downstream page break, breaking the pixel-perfect overlay. So we
% MEASURE the bare text, then declare the framed box's metrics back down to it and let
% the frame paint OUTSIDE (over the inter-choice / cell whitespace):
%   \sbox        capture the bare text's \ht/\dp/\wd;
%   \raisebox[][] force the (taller) frame to report the bare height/depth (it
%                overflows top/bottom for free);
%   \makebox[..][l] reserve only the bare width (frame overflows right);
%   \kern-(rule+sep) slide the frame left so the TEXT stays x-aligned with the other
%                choices (frame overflows into the "(A)" gap on the left).
% Works uniformly for all three layouts and \graphchoice, since the output is simply
% "a box with the bare content's metrics". \SolutionCueSep is kept modest so the
% overflow into neighbours stays subtle. Retune the \SolutionCue* knobs above.
\newsavebox{\cc@inner}
\newcommand{\CorrectChoiceFormat}[1]{%
  \begingroup
    \sbox\cc@inner{#1}%
    \makebox[\wd\cc@inner][l]{%
      \kern-\dimexpr\SolutionCueRule+\SolutionCueSep\relax
      \raisebox{\z@}[\ht\cc@inner][\dp\cc@inner]{%
        \SolutionCueBox{\usebox\cc@inner}%
      }%
    }%
  \endgroup
}

% Shared: render option text, boxed iff this \choice is the key AND solutions on.
% \choice resolves correctness (from the optional arg) into \choice@iscorrect,
% then hands the text to the current layout's emitter.
\newcommand{\choice@iscorrect}{0}
\newcommand{\choice@content}[1]{%
  \ifdefstring{\choice@iscorrect}{1}%
    {\ifsolutions\CorrectChoiceFormat{#1}\else#1\fi}{#1}%
}
\NewDocumentCommand{\choice}{o m}{%
  \stepcounter{choice}%
  \IfNoValueTF{#1}{\def\choice@iscorrect{0}}{\def\choice@iscorrect{1}}%
  \csname choice@@\choice@layout\endcsname{#2}%
}

% Per-layout emitters (each gets the option text as #1). All route the label
% through \ChoiceLabelFormat so the label style (plain vs check-in colors) is set
% in one place by the enclosing environment.
\newcommand{\choice@@stacked}[1]{%
  \item[\ChoiceLabelFormat{\Alph{choice}}]\choice@content{#1}}
\newcommand{\choice@@onepar}[1]{%
  \choice@sep\ChoiceLabelFormat{\Alph{choice}}~\choice@content{#1}\let\choice@sep\qquad}
% Grid: separator BEFORE each cell (safe: \hfill / \par\nobreak, never & / \\).
\newcommand{\choice@@grid}[1]{%
  \ifnum\choice@col=0 \else
    \ifnum\choice@col<\numexpr\ChoicesGridCols\relax
      \hfill
    \else
      \global\choice@col=0 \par\nobreak
    \fi
  \fi
  \ifnum\choice@col=0 \noindent\fi
  \parbox[t]{\choice@gridwidth}{\ChoiceLabelFormat{\Alph{choice}}~\choice@content{#1}}%
  \global\advance\choice@col1
}

% Per-layout environment begin/end, dispatched by the optional argument.
\newcommand{\choices@begin@stacked}{%
  \list{}{%
    \ifcheckinmode
      % Roomier: the colored label boxes are wider and taller than "(A)". topsep
      % is 0 -- the gap before the list is \CheckinBodySkip, added in `choices'.
      \setlength{\leftmargin}{3em}\setlength{\labelwidth}{2.4em}%
      \setlength{\labelsep}{0.6em}\setlength{\itemsep}{10pt}%
      \setlength{\topsep}{0pt}%
    \else
      \setlength{\leftmargin}{2.5em}\setlength{\labelwidth}{2em}%
      \setlength{\labelsep}{0.5em}\setlength{\itemsep}{0.2ex}%
      \setlength{\topsep}{0.4\baselineskip}%
    \fi}%
}
\newcommand{\choices@end@stacked}{\endlist}
\newcommand{\choices@begin@onepar}{\let\choice@sep\empty\noindent\ignorespaces}
\newcommand{\choices@end@onepar}{\par}
\newcommand{\choices@begin@grid}{%
  \global\choice@col=0
  \setlength{\choice@gridwidth}{\dimexpr\linewidth/\ChoicesGridCols - 1.5em\relax}%
  \par}
\newcommand{\choices@end@grid}{\par}

\NewDocumentEnvironment{choices}{O{stacked}}{%
  \par\setcounter{choice}{0}%
  \def\choices@req{#1}%
  % Check-in only swaps the label style (colored boxes); the file's chosen layout
  % (stacked/onepar/grid) is respected.
  \ifcheckinmode
    \let\ChoiceLabelFormat\CheckinChoiceLabel
    \vspace{\CheckinBodySkip}% gap after the stem, before the choices (any layout)
  \fi
  \@ifundefined{choices@begin@\choices@req}%
    {\PackageError{Exercises}{Unknown choices layout `\choices@req'}%
       {Use one of: stacked, onepar, grid.}}%
    {\edef\choice@layout{\choices@req}\csname choices@begin@\choices@req\endcsname}%
}{%
  \csname choices@end@\choice@layout\endcsname
}

% \graphchoice[correct]{FILE} -- a \choice whose content is a GRAPH, for a
% [grid] of graphs. It (1) sizes the image to the column minus room for the "(A)"
% label, so the label sits BESIDE the graph without overflowing, and (2) vertically
% aligns the graph against the label per \GraphChoiceValign: c=middle (default,
% the least ambiguous), t=label at the graph's top, b=label at its bottom. The
% alignment lives here, on the graph, NOT on the grid -- so a grid of plain text
% \choice options keeps its correct baseline alignment. Middle is just a raisebox:
% centre the image on the label's baseline. Restyle width/alignment in one place.
\newcommand{\GraphChoiceValign}{c}
\newcommand{\graphchoice@raise}[1]{%
  \ifdefstring{\GraphChoiceValign}{t}{\raisebox{-\height}{#1}}{%
    \ifdefstring{\GraphChoiceValign}{b}{#1}{\raisebox{-0.5\height}{#1}}}%
}
% Width reserved beside a graph for its label, so image + label fit the column.
% Tuned for MC's narrow "(A)" labels; \renewcommand to widen where labels are
% wider (the matching env bumps it for its [iii]-class \roman labels).
\newcommand{\GraphLabelReserve}{2.4em}
\newcommand{\graphchoice@box}[1]{%
  \graphchoice@raise{\includegraphics[width=\dimexpr\linewidth-\GraphLabelReserve\relax]{#1}}%
}
\NewDocumentCommand{\graphchoice}{o m}{%
  \IfNoValueTF{#1}%
    {\choice{\graphchoice@box{#2}}}%
    {\choice[#1]{\graphchoice@box{#2}}}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% MATCHING
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Like MC, a matching question is a normal \begin{problem} whose body is a
% \begin{matching}: a LEFT column of items [i],[ii],... and a RIGHT column [A],[B],...
% with a wide gap for students to draw connecting lines. \rightcolumn splits the two.
% Items may be text (\leftitem/\rightitem) or graphs (\leftgraph/\rightgraph, which
% reuse \graphchoice's sizing + centring):
%
%   \begin{problem}
%     Match each graph with the phrase that best describes it.
%     \begin{matching}
%       \leftgraph[C]{graph-1}    % this left item's match is right item [C]
%       \leftgraph[A]{graph-2}
%       \rightcolumn
%       \rightitem{Concave up}    % [A]
%       \rightitem{Concave down}  % [B]
%       ...
%     \end{matching}
%   \end{problem}
%
% The answer is intrinsic, like \choice[correct]: a left item names its match in
% the optional argument. In a SOLUTIONS build that match is shown inline next to
% the item ("(1) [graph] $\to$ C"), gated by \ifsolutions -- deliberately NO drawn
% arrows (they are only aesthetic and would force a TikZ dependency + a two-pass
% compile). Left/right counts may differ (distractors). Tunables: \MatchColWidth
% (each column; the remainder is the gap), \MatchItemSep, \MatchKeyFormat.
%
% Two columns are two side-by-side \minipage[c]s; \rightcolumn ends the left one
% and opens the right (raw \minipage/\endminipage so the split can straddle it).
% [c] (not [t]) so the columns center against each other: when one side is short
% (e.g. phrases) and the other tall (e.g. graphs), the short column floats to the
% vertical middle of the tall one, giving a symmetric connecting-line gap instead
% of a lopsided bottom wedge. Degrades gracefully with unequal counts -- no row
% pairing is assumed. (If even spacing within the columns is later wanted, that
% is the heavier measure-both-then-distribute job -- parked, not built.)
\newcounter{matchleft}
\newcounter{matchright}
\newlength{\match@colwidth}
\newcommand{\MatchColWidth}{0.38\linewidth}
\newcommand{\MatchItemSep}{2ex}
% The match annotation is encased in the shared \SolutionCueBox (the same green
% frame + light fill as a boxed correct MC option) -- so "-> [C]" reads as
% "this is the answer" consistently, by construction. The target is bracketed to
% mirror the right column's own [A][B] labels.
\newcommand{\MatchKeyFormat}[1]{%
  \;\SolutionCueBox{\bfseries\color{SolutionColor}$\to$[#1]}}

% The two columns use DISTINCT enumeration systems, both in SQUARE brackets (round
% brackets are taken by (parts)/(points), and Crowdmark bubbles are rectangular):
% the left items are lowercase-roman [i][ii][iii], the right items uppercase-alpha
% [A][B][C]. Distinct styles are the classic matching convention -- "match [i] to
% [C]" can never confuse a left label for a right one. The annotation rides on the
% left label -- "[i] -> [C]" -- not after the content, so it always fits even when
% the content is a column-filling graph (trailing text would wrap below it).
\NewDocumentCommand{\leftitem}{o m}{%
  \par\stepcounter{matchleft}%
  \noindent[\roman{matchleft}]%
  \IfNoValueF{#1}{\ifsolutions\MatchKeyFormat{#1}\fi}%
  \quad #2%
  \par\vspace{\MatchItemSep}%
}
\NewDocumentCommand{\rightitem}{m}{%
  \par\stepcounter{matchright}%
  \noindent[\Alph{matchright}]\quad #1%
  \par\vspace{\MatchItemSep}%
}
\NewDocumentCommand{\leftgraph}{o m}{%
  \IfNoValueTF{#1}%
    {\leftitem{\graphchoice@box{#2}}}%
    {\leftitem[#1]{\graphchoice@box{#2}}}%
}
\newcommand{\rightgraph}[1]{\rightitem{\graphchoice@box{#1}}}

\newcommand{\rightcolumn}{\endminipage\hfill\minipage[c]{\match@colwidth}}
\newenvironment{matching}{%
  \par\setcounter{matchleft}{0}\setcounter{matchright}{0}%
  \setlength{\match@colwidth}{\MatchColWidth}%
  % [iii]-class \roman labels + \quad are wider than MC's "(A)"; give a left graph
  % more label room so [iii]\quad<graph> doesn't overrun the column (local to env).
  \renewcommand{\GraphLabelReserve}{3em}%
  \par\noindent\minipage[c]{\match@colwidth}%
}{%
  \endminipage\par
}
